<Project Sdk="Microsoft.NET.Sdk.Web">

	<PropertyGroup>
		<TargetFramework>net5.0</TargetFramework>
		<SuppressTfmSupportBuildWarnings>true</SuppressTfmSupportBuildWarnings>
		<MvcBuildViews>false</MvcBuildViews>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>

		<!-- ✅ 關掉 StyleCop 分析錯誤（SA0001） -->
		<RunAnalyzersDuringBuild>true</RunAnalyzersDuringBuild>
		<EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>


		<EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
		<!-- 設定報告格式，這邊是 XML，也可以換成 SARIF -->
		<ErrorLog>reports/StyleCopReport.sarif</ErrorLog>
		<!-- 或 StyleCopReport.xml -->
		<ErrorLogFormat>Sarif</ErrorLogFormat>
		<!-- 也可以寫成 Xml -->
	</PropertyGroup>

	<ItemGroup>
	  <Compile Remove="Models\ErrorViewModel - 複製.cs" />
	  <Compile Remove="Models\HomeController.cs" />
	</ItemGroup>

	<!-- <ItemGroup Condition=" '$(SkipMetaTraderPackages)' != 'true' "> -->
	<!-- <PackageReference Include="MetaTrader4.Manager.ClrWrapperCore.x64" Version="1.1420.1" /> -->
	<!-- <PackageReference Include="MetaTrader5.Manager.x64" Version="0.4380.1" /> -->
	<!-- </ItemGroup> -->

	<ItemGroup>
		<Reference Include="MetaQuotes.MT5CommonAPI64">
			<HintPath>lib\MTApi\MetaQuotes.MT5CommonAPI64.dll</HintPath>
			<Private>true</Private>
		</Reference>
		<Reference Include="MetaQuotes.MT5ManagerAPI64">
			<HintPath>lib\MTApi\MetaQuotes.MT5ManagerAPI64.dll</HintPath>
			<Private>true</Private>
		</Reference>
		<Reference Include="MT5APIManager64">
			<HintPath>lib\MTApi\MT5APIManager64.dll</HintPath>
			<Private>true</Private>
		</Reference>
		<Reference Include="mtmanapi64">
			<HintPath>lib\MTApi\mtmanapi64.dll</HintPath>
			<Private>true</Private>
		</Reference>
		<Reference Include="P23.MetaTrader4.Manager.ClrWrapperCore">
			<HintPath>lib\MTApi\P23.MetaTrader4.Manager.ClrWrapperCore.dll</HintPath>
			<Private>true</Private>
		</Reference>
		<Reference Include="P23.MetaTrader4.Manager.ContractsCore">
			<HintPath>lib\MTApi\P23.MetaTrader4.Manager.ContractsCore.dll</HintPath>
			<Private>true</Private>
		</Reference>
