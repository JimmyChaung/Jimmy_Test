	<ItemGroup>
		<PackageReference Include="BestDataServer.MT4.x64" Version="0.4.0" />
		<PackageReference Include="Coravel" Version="4.0.1" />
		<PackageReference Include="CsvHelper" Version="32.0.3" />
		<PackageReference Include="Dapper" Version="2.1.66" />
		<PackageReference Include="DocX" Version="5.0.0" />
		<PackageReference Include="EPPlus" Version="7.1.3" />
