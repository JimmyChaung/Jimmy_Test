                        }
                        */
                    },
                    error: function () {
                        $("#modifyLogSelect").empty().append('<option value="">無可用歷史資料</option>');
                    }
                });
            }


        });






        




        //查詢API
        function runSearchExe() {
            //showLoading("正在執行 Pamm Rollover API查詢");

            var formData = new FormData();
            formData.append('tool_path', 'Pamm_Rollover');
            formData.append('output_path', 'log');
            formData.append('exe_name', "check.exe");
            formData.append('DeleteAllFile', false);
            return $.ajax({
                url: '@Url.Action("RunExe_rollover", "DataProduct")',
                type: 'POST',
                data: formData,
                contentType: false,
                processData: false,
                beforeSend: function () {
                    //showLoading("正在執行 Pamm Rollover API查詢");
                    $('#myTabContent').hide();
                },
                success: function (response) {
                    //location.reload(true); // 重新整理
                    console.log("API search success")

                    // reset DataTable
                    if ($.fn.DataTable.isDataTable('#status_datatable')) {
                        $('#status_datatable').DataTable().clear().destroy();
                    }

                },
                error: function (error) {
                    //hideLoading();
                    //$('#RunButton').prop('disabled', false);
                    //$('#uploadInput').prop('disabled', false);
                    //$('#Download').prop('disabled', false);
                    //$('#inputFile').prop('disabled', false);
                    //$('#Setting').prop('disabled', false);
                    //$('#RunResult').html(`<p class="text-danger">${error.responseText}</p>`);
                    console.log("error in api")
                    //hideLoading();
                }
            });
        }

        // 顯示結果
        function RefreshstatusApi() {
            return $.ajax({
                url: '@Url.Action("Refreshstatus", "DataProduct")', //
                type: 'POST',
                data: {}, //{ server: serversel },
                success: function (data) {
                    // 清空舊的表格內容
                    $('#rstatus_tbody').empty();
                   // console.log(data)
                    // 生成新的表格資料
                    $.each(data, function (index, row) {
                        var newRow = '<tr>';
                        $.each(row, function (key, value) {
                            newRow += '<td>' + value + '</td>';
                        });
                        newRow += '</tr>';
                        $('#rstatus_tbody').append(newRow);
                    });
                    // 3. 重新初始化 DataTable
                    $('#status_datatable thead').show();

                    var table = $('#status_datatable').DataTable({
                        responsive: true,
                        scrollX: true,
                        columnDefs: [
                            { className: "text-center", targets: "_all" } // 將所有列的文字置中
                        ],
                        "bInfo": false,// 隱藏表格資訊
                            pageLength: 25
                    });

                    table.draw();
                    //hideLoading();
                },
                error: function (xhr, status, error) {
                    console.log("更新失敗: " + error);
                    //hideLoading();
                }
             });
        }

