    <script>




        $('#updatestatus').on('click', function () {
            if (!confirm("確定要執行 Pamm Rollover API 查詢狀態嗎？")) {
                return; // 如果按取消，則不執行 AJAX
            }

            showLoading("正在執行 Pamm Rollover API查詢");
            // exe
            $.ajax({
                url: '/Universal/Insert_Usage_Log',
                type: 'POST',
                data: {
                    Tool: 'Pamm Rollover API',
                    Remark: '執行查詢狀態工具'
                },
