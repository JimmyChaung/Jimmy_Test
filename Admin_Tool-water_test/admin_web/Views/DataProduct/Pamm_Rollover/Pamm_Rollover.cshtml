                            ],
                            order: [],
                            pageLength: 15,
                            lengthChange: false,
                        });
                    } else {
                        console.error("無有效資料");
                    }
                },
                error: function (error) {
                    console.log(error);
                },
                complete: function () {
                    hideLoading();
                }
            });
        });

        //upload
        $(document).ready(function () {
            $("#uploadInput").on("click", function () {
                let fileInput = $("#uploadCSV")[0].files[0];

                if (!fileInput) {
                    alert("請選擇檔案");
                    return;
                }

                // 檢查檔名
                if (fileInput.name !== "pammManagerRolloverConfig.csv") {
                    alert("請上傳檔名為 pammManagerRolloverConfig.csv 的檔案");
                    return;
                }

                let formData = new FormData();
                formData.append("file", fileInput);

                $.ajax({
                    url: '@Url.Action("UploadsetCSV", "DataProduct")',
                    type: 'POST',
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (response) {
                        alert(response.message);
                        location.reload(); // 重新載入頁面
                    },
                    error: function (error) {
                        console.log("fail upload")
                        alert("上傳失敗 error message：" + error.responseText);
                    }
                });
            });
        });

        //error modal
        $(document).ready(function () {
            $("#errorLogModal").on("show.bs.modal", function () {
                loadTodayLog();
            });

            function loadTodayLog() {
                $.ajax({
                    url: "/DataProduct/GetErrorFileContent",  
                    type: "GET",
                    success: function (data) {
                        $("#errorLogContent").text(data);
                    },
                    error: function (xhr, status, error) {
                        $("#errorLogContent").text("讀取失敗：" + xhr.responseText);
                    }
                });
            }
        });



        //modify log
        $(document).ready(function () {
            //let dataTableInstance = null;  // 用來儲存 DataTable 例項

            loadModifyLogFiles();

            $("#modifyLogSelect").change(function () {
                let selectedFile = $(this).val();
                if (selectedFile) {
                    loadModifyLogContent(selectedFile);
                } else {
                    $("#modifyLogTable tbody").html('<tr><td colspan="8" class="text-center">請選擇日期</td></tr>');
                }
            });

            function loadModifyLogFiles() {
                $.ajax({
                    url: "/DataProduct/GetModifyLogFiles",
                    type: "GET",
                    success: function (data) {
                        let select = $("#modifyLogSelect");
                        select.empty();
                        select.append('<option value="">...</option>');

                        data.forEach(function (fileName) {
                            select.append(`<option value="${fileName}">${fileName}</option>`);
                        });
                        /*
                        if (data.length > 0) {
                            select.val();//(data[0]).change();
                        }
                        */
                    },
                    error: function () {
                        $("#modifyLogSelect").empty().append('<option value="">無可用歷史資料</option>');
                    }
                });
            }

            function loadModifyLogContent(fileName) {
                $.ajax({
                    url: "/DataProduct/GetModifyLogContent",
                    type: "GET",
                    data: { fileName: fileName },
                    success: function (data) {
                        formatCSVToTable(data);
                    },
                    error: function () {
                        $("#modifyLogTable tbody").html('<tr><td colspan="8" class="text-center">讀取失敗</td></tr>');
                    }
                });
            }

            function formatCSVToTable(csvText) {
                let rows = csvText.trim().split("\n");
                let table = $("#modifyLogTable");

                // 清空表格內容
                if ($.fn.DataTable.isDataTable(table)) {
                    table.DataTable().destroy();
                }

                let tableHead = $("#modifyLogTable thead");
                let tableBody = $("#modifyLogTable tbody");

                tableHead.empty();
                tableBody.empty();

                if (rows.length === 0) {
                    tableBody.append('<tr><td colspan="8" class="text-center">無資料</td></tr>');
                    return;
                }

                // 重新設定表頭
                let headers = rows[0].split(",");
                let theadRow = "<tr>";
                headers.forEach(header => {
                    theadRow += `<th>${header.trim()}</th>`;
                });
                theadRow += "</tr>";
                tableHead.html(theadRow);

                // 重新設定表格數據
                let data = [];
                rows.slice(1).forEach(function (row) {
                    data.push(row.split(",").map(col => col.trim()));
                });

                // 重新初始化 DataTable
                table.DataTable({
                    data: data,
                    columns: headers.map(header => ({ title: header.trim() })), // 設定 DataTable 的標題
                    responsive: true,
                    scrollX: true,
                    pageLength: 25,
                    columnDefs: [
                        { className: "text-center", targets: "_all" }
                    ],
                    "bInfo": false,
                    "destroy": true,
                    "order": []
                });
            }

        });

        $("#toggleLogSectionBtn").click(function () {

            

            let logSection = $("#logSection");

            if (logSection.is(":visible")) {
                logSection.slideUp();
                $(this).text("顯示修改紀錄");
            } else {
                loadModifyLogFiles();

                logSection.slideDown(function () {


                    

                    if (!$.fn.DataTable.isDataTable("#modifyLogTable")) {
                        $("#modifyLogTable").DataTable({
                            responsive: true,
                            scrollX: true,
                            autoWidth: false,
                            pageLength: 25 ,
                            columnDefs: [{ className: "text-center", targets: "_all" }],
                            "bInfo": false,
                            "order": []
                        });
                    }
                    $('#modifyLogTable').DataTable().columns.adjust().draw();
                });
                $(this).text("隱藏修改紀錄");
                
            }

            function loadModifyLogFiles() {
                $.ajax({
                    url: "/DataProduct/GetModifyLogFiles",
                    type: "GET",
                    success: function (data) {
                        let select = $("#modifyLogSelect");
                        select.empty();
                        select.append('<option value="">...</option>');

                        data.forEach(function (fileName) {
                            select.append(`<option value="${fileName}">${fileName}</option>`);
                        });
                        /*
                        if (data.length > 0) {
