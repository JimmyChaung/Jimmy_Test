@model admin_web.Models.DataProduct.PammRollover_Model
@{
    ViewData["Title"] = "Pamm Rollover 自動化";
    List<string> FileNameList = ViewBag.FileNameList as List<string>;
    string FileSelect = ViewBag.SelectDate as string;
    int index = 1;
}
<head>
    <meta charset="utf-8" />
    <style type="text/css">

        .container {
            padding: 0 15px;
        }

        .nav-tabs {
            white-space: nowrap;
            overflow-x: auto;
            overflow-y: hidden;
            -webkit-overflow-scrolling: touch;
        }

        .nav-item {
            flex: 0 0 auto;
        }
        #modifyLogTable th,
        #modifyLogTable td {
            white-space: nowrap; 
        }
    </style>

</head>

<body>
    <h1>Pamm Rollover 自動化</h1>

    <button class="btn btn-outline-primary" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasScrolling" aria-controls="offcanvasScrolling">Server修改列表</button>


    <button type="submit" id="updatestatus" class="btn btn-success">立即查看所有Manager當前狀態</button>

    <button type="submit" id="modifystatus_True" class="btn btn-success">修改Request settings (打開)</button>

    <button type="submit" id="modifystatus_False" class="btn btn-success">修改Request settings (關閉)</button>

    <p></p>

    <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#errorLogModal" >
        查看執行錯誤紀錄
    </button>


    <!-- Modal -->
    <div class="modal fade" id="errorLogModal" tabindex="-1" aria-labelledby="errorLogModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="errorLogModalLabel">當日執行錯誤紀錄</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <pre id="errorLogContent">讀取中...</pre>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">關閉</button>
                </div>
            </div>
        </div>
    </div>


    <p></p>

    <div class="form-group d-flex align-items-center">
        <input id="uploadCSV" type="file" name="inputFile" accept=".csv" class="form-control me-2" style="max-width: 600px;" />
        <button type="submit" id="uploadInput" class="btn btn-primary">重新上傳設定檔</button>
    </div>
    <div id="uploadInputResult1"></div>

    <p style="color:red" ;><i class="bi bi-exclamation-triangle-fill"></i> 當前系統時間與台北時間時差：5 </p>


    <hr>


    <table id="status_datatable" class="table table-striped table-bordered nowrap">
        <thead style="display:none;">
            <tr>
                <th>Pamm_Server</th>
                <th>Cfg id</th>
                <th>Cfg Name</th>
                <th>managerCanConfirm</th>
                <th>managerCanWithdraw</th>
                <th>managerCanConfirmDeposit</th>
                <th>managerCanConfirmWithdraw</th>
                <th>managerCanConfirmCloseAccount</th>
                <th>Time</th>
            </tr>
        </thead>
        <tbody id="rstatus_tbody">
        </tbody>
    </table>

    <hr>

    <button id="toggleLogSectionBtn" class="btn btn-primary mb-3">顯示修改歷史紀錄</button>

    <div id="logSection" class="card" style="display: none;">
        <div class="card-header">
            <h5>修改歷史紀錄 (刷新資料請重新選擇日期or重新點擊顯示/隱藏修改紀錄按鈕)</h5>
        </div>
        <div class="card-body">
            <label for="modifyLogSelect">選擇日期：</label>
            <select id="modifyLogSelect" class="form-select mb-3">
                <option value="">...</option>
            </select>

            <div class="table-responsive mt-3">
                <table id="modifyLogTable" class="table table-striped table-bordered">
                    <thead></thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>



    <!-- Scrolling -->
    <div class="offcanvas offcanvas-end" data-bs-scroll="true" data-bs-backdrop="false" tabindex="-1" id="offcanvasScrolling" aria-labelledby="offcanvasScrollingLabel" style="width:500px;">
        <div class="offcanvas-header">
            <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            <h5 class="offcanvas-title" id="offcanvasScrollingLabel">Server設定檔列表</h5>
        </div>
        <div class="offcanvas-body">
            <table id="ServerList" class="table table-striped"></table>
        </div>
    </div>


    <hr>



</body>

@section Scripts {
