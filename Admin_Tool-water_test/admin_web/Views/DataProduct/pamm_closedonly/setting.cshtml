@model List<admin_web.Models.DataProduct.pamm_closedonlyModel.PmRecord>;
<head>
    <meta charset="UTF-8" />
    <!-- Bootstrap CSS -->
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .table-wrapper {
            overflow-x: auto;
            width: 100%;
        }

        .dataTables_wrapper .dataTables_paginate {
            margin-top: 10px; /* 設置分頁與表格間的距離 */
        }
    </style>
</head>

<body>
    <h1>@ViewData["Title"] - PM設置</h1>
    <div class="container" style="margin-bottom:50px">
        <!-- 返回主頁 -->
        <div class="btn-group" role="group" aria-label="Basic example">
            <a href="@Url.Action("pamm_closedonly", "DataProduct")"
               class="btn btn-outline-primary" role="button">返回工具主頁</a>
        </div>

        <!-- 主表格 -->
        <table id="PmTable" class="table table-bordered">
            <thead>
                <tr>
                    <th style="width: 20%">SQL</th>
                    <th style="width: 20%">Host</th>
                    <th style="width: 40%">Mt4 Server</th>
                    <th style="width: 20%">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var record in Model)
                {
                    <tr>
                        <td>@record.sql_na</td>
                        <td>@record.host</td>
                        <td>@record.mt4_server</td>
                        <td>
                            <button type="button" class="btn btn-primary btn-sm edit-btn"
                                    data-original-sql_na="@record.sql_na"
                                    data-sql_na="@record.sql_na" 
                                    data-host="@record.host" 
                                    data-user="@record.user" 
                                    data-password="@record.password" 
                                    data-mt4_server="@record.mt4_server" 
                                    data-floating_configid="@record.Floating_configid" 
                                    data-no_color_configid="@record.No_Color_configid" 
                                    data-test_id="@record.Test_Id" 
                                    data-special_approve_login="@record.Special_Approve_Login"
                                    >Edit</button>
                            <button type="button" class="btn btn-danger btn-sm delete-btn">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <button type="button" class="btn btn-primary btn-sm modal-add-btn">Add</button>

        <!-- 編輯用Modal-->
        <div class="modal fade" id="editModal" tabindex="-1" role="dialog" aria-labelledby="editModalLabel" aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="editModalLabel">Edit Record</h5>
                        <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <form id="editForm">
                            <div class="form-group">
                                <label for="sql_na">SQL</label>
                                <input type="text" id="sql_na" class="form-control sql_na-edit" />

                                <label for="host">Host</label>
                                <input type="text" id="host" class="form-control host-edit" />

                                <label for="user">user</label>
                                <input type="text" id="user" class="form-control user-edit" />

                                <label for="password">password</label>
                                <input type="text" id="password" class="form-control password-edit" />

                                <label for="mt4_server">mt4_server</label>
                                <input type="text" id="mt4_server" class="form-control mt4_server-edit" />

                                <label for="floating_configid">Floating_configid</label>
                                <input type="text" id="floating_configid" class="form-control Floating_configid-edit" />

                                <label for="no_color_configid">No_Color_configid</label>
                                <input type="text" id="no_color_configid" class="form-control No_Color_configid-edit" />

                                <label for="test_id">Test_Id</label>
                                <input type="text" id="test_id" class="form-control Test_Id-edit" />

                                <label for="special_approve_login">Special_Approve_Login</label>
                                <input type="text" id="special_approve_login" class="form-control Special_Approve_Login-edit" />
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary update-btn" >Save changes</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 新增用Modal-->
        <div class="modal fade" id="addModal" tabindex="-1" role="dialog" aria-labelledby="addModalLabel" aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="addModalLabel">新增設置</h5>
                        <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                            <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <form id="editForm">
                            <div class="form-group">
                                <label for="sql_na">SQL</label>
                                <input type="text" class="form-control sql_na-add" />

                                <label for="host">Host</label>
                                <input type="text" class="form-control host-add" />

                                <label for="user">user</label>
                                <input type="text" class="form-control user-add" />

                                <label for="password">password</label>
                                <input type="text" class="form-control password-add" />

                                <label for="mt4_server">mt4_server</label>
                                <input type="text" class="form-control mt4_server-add" />

                                <label for="floating_configid">Floating_configid</label>
                                <input type="text" class="form-control Floating_configid-add" />

                                <label for="no_color_configid">No_Color_configid</label>
                                <input type="text" class="form-control No_Color_configid-add" />

                                <label for="test_id">Test_Id</label>
                                <input type="text" class="form-control Test_Id-add" />

                                <label for="special_approve_login">Special_Approve_Login</label>
                                <input type="text" class="form-control Special_Approve_Login-add" />
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary add-btn">Upload</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS and dependencies -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>

    <script src="https://code.jquery.com/jquery-3.7.1.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.3/umd/popper.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.3/js/dataTables.js"></script>

    <script src="https://cdn.datatables.net/2.0.3/js/dataTables.bootstrap4.js"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.1/js/dataTables.responsive.js"></script>
    <script src="https://cdn.datatables.net/responsive/3.0.1/js/responsive.bootstrap4.js"></script>

    <script>
        $(document).ready(function () {
            showLoading("Loading");

            setTimeout(function () {
                hideLoading();
                $('.content').show();
                $('#myTabContent [id^="section"] table').each(function () {
                    $(this).DataTable({
                        responsive: true,
                    });
                });
            }, 1000);
        });

        // 讀取動畫(開啟)
        function showLoading(text) {
            $('body').append('<div id="loadingOverlay" class="loading-overlay"><div class="spinner-container"><div class="spinner"></div>' + text + '</div></div>');
        }

        // 讀取動畫(移除)
        function hideLoading() {
            $('#loadingOverlay').remove();
        }

        $(document).ready(function () {
            // 刷新
            function refreshTable() {
                location.reload();
            }

            // 新增
            $('.add-btn').click(function () {
                var sql_na = $('#addModal .sql_na-add').val();
                var host = $('#addModal .host-add').val();
                var user = $('#addModal .user-add').val();
                var password = $('#addModal .password-add').val();
                var mt4_server = $('#addModal .mt4_server-add').val();
                var Floating_configid = $('#addModal .Floating_configid-add').val();
                var No_Color_configid = $('#addModal .No_Color_configid-add').val();
                var Test_Id = $('#addModal .Test_Id-add').val();
                var Special_Approve_Login = $('#addModal .Special_Approve_Login-add').val();

                $.ajax({
                    url: '/DataProduct/pamm_closedonly_PmRecords_Add',
                    type: 'POST',
                    data: {
                        sql_na: sql_na,
                        host: host,
                        user: user,
                        password: password,
                        mt4_server: mt4_server,
                        Floating_configid: Floating_configid,
                        No_Color_configid: No_Color_configid,
                        Test_Id: Test_Id,
                        Special_Approve_Login: Special_Approve_Login
                    },
                    success: function (response) {
                        if (response.success) {
                            refreshTable(); // 如果操作成功，刷新表格
                        } else {
                            alert(response.message); // 如果操作失敗，顯示錯誤訊息
                        }
                    }
                });
            });

            // 編輯
            $('.edit-btn').click(function () {
                $('#sql_na').val($(this).data('sql_na'));
                $('#host').val($(this).data('host'));
                $('#user').val($(this).data('user'));
                $('#password').val($(this).data('password'));
                $('#mt4_server').val($(this).data('mt4_server'));
                $('#floating_configid').val($(this).data('floating_configid'));
                $('#no_color_configid').val($(this).data('no_color_configid'));
                $('#test_id').val($(this).data('test_id'));
                $('#special_approve_login').val($(this).data('special_approve_login'));
                $('.sql_na-edit').each(function () {
                    var originalValue = $(this).val();
                    $(this).attr('data-original-sql_na', originalValue);
                });
                $('#editModal').modal('show');
            });

            // 顯示新增Modal
            $('.modal-add-btn').click(function () {
                $('#addModal').modal('show');
            });

            // 更新
            $('.update-btn').click(function () {
                var original_sql_na = $('#editModal .sql_na-edit').data('original-sql_na');

                var new_sql_na = $('#editModal .sql_na-edit').val();
                var new_host = $('#editModal .host-edit').val();
                var new_user = $('#editModal .user-edit').val();
                var new_password = $('#editModal .password-edit').val();
                var new_mt4_server = $('#editModal .mt4_server-edit').val();
                var new_Floating_configid = $('#editModal .Floating_configid-edit').val();
                var new_No_Color_configid = $('#editModal .No_Color_configid-edit').val();
                var new_Test_Id = $('#editModal .Test_Id-edit').val();
                var new_Special_Approve_Login = $('#editModal .Special_Approve_Login-edit').val();

                console.log(original_sql_na);

                $.ajax({
                    url: '/DataProduct/pamm_closedonly_PmRecords_Edit',
                    type: 'POST',
                    data: {
                        sql_naBefore: original_sql_na,
                        sql_naAfter: new_sql_na,
                        hostAfter: new_host,
                        userAfter: new_user,
                        passwordAfter: new_password,
                        mt4_serverAfter: new_mt4_server,
                        Floating_configidAfter: new_Floating_configid,
                        No_Color_configidAfter: new_No_Color_configid,
                        Test_IdAfter: new_Test_Id,
                        Special_Approve_LoginAfter: new_Special_Approve_Login
                    },
                    success: function (response) {
                        console.log(response);
                        if (response.success) {
                            refreshTable();
                        } else {
                            alert(response.message);
                        }
                    }
                });
            });

            // 刪除
            $('.delete-btn').click(function () {
                var row = $(this).closest('tr');
                var sql_na = row.find('td').eq(0).text().trim();

                if (confirm(`您確定要刪除${sql_na}的設置嗎？`)) {
                    $.ajax({
                        url: '/DataProduct/pamm_closedonly_PmRecords_Delete',
                        type: 'POST',
                        data: {
                            sql_na: sql_na
                        },
                        success: function (response) {
                            if (response.success) {
                                refreshTable(); // 如果操作成功，刷新表格
                            } else {
                                alert(response.message); // 如果操作失敗，顯示錯誤訊息
                            }
                        }
                    });
                }
            });
        });

    </script>

    @* Bootstrap 5 *@
    <!-- CSS only -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-F3w7mX95PdgyTmZZMECAngseQB83DfGTowi0iMjiWaeVhAn4FJkqJByhZMI3AhiU" crossorigin="anonymous">

    <!-- JavaScript Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.1/dist/js/bootstrap.bundle.min.js" integrity="sha384-/bQdsTh/da6pkI1MST/rWKFNjaCP5gBSY4sEBT38Q/9RBh9AH40zEOg7Hlq2THRZ" crossorigin="anonymous"></script>
}
