<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
</head>
<body>
    <h1>@ViewData["Title"]</h1>

    <div class="row mb-3">
        <div class="col-md-6">
            <div class="input-group">
                <label class="input-group-text" for="BeforeFileInput">Files Before</label>
                <input type="file" class="form-control" name="before_files[]" multiple="multiple" required="required" draggable="true" id="BeforeFileInput" accept=".csv" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="input-group">
                <label class="input-group-text" for="AfterFileInput">Files After</label>
                <input type="file" class="form-control" name="after_files[]" multiple="multiple" required="required" draggable="true" id="AfterFileInput" accept=".csv" />
            </div>
        </div>
    </div>

    <div class="input-group mb-3">
        <span class="input-group-text" id="inputGroup-sizing-default">Primary Key</span>
        <input type="text" id="PrimaryKeyInput" class="form-control" placeholder="請輸入 Primary Key，若有多個請用 , 做區隔" />
    </div>

    <div class="mt-3">
        <button type="button" class="btn btn-primary" id="ExecuteButton">執行</button>
        <a id="DownloadButton" class="btn btn-success disabled" style="pointer-events: none;">下載結果</a>
    </div>
</body>
</html>

@section Scripts {
    <!-- Bootstrap 5 Bundle (includes Popper.js) -->
    <script src="https://cdn.datatables.net/1.13.3/js/jquery.dataTables.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/2.1.4/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/2.1.4/js/dataTables.bootstrap5.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/fixedcolumns/5.0.1/js/dataTables.fixedColumns.js"></script>
    <script src="https://cdn.datatables.net/fixedcolumns/5.0.1/js/fixedColumns.bootstrap5.js"></script>

    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.3/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/2.1.4/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.0/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/fixedcolumns/5.0.1/css/fixedColumns.bootstrap5.css">

    <script>
        $(document).ready(function () {
            $("#ExecuteButton").click(function () {
                $.ajax({
                    url: '/Universal/Insert_Usage_Log',
                    type: 'POST',
                    data: {
                        Tool: '萬用比對工具',
                        Remark: '執行工具'
                    },
                    success: function () {
                        console.log("Log Insert Success.");
                    },
                    error: function (xhr, status, error) {
                        console.error("Error triggering log insertion:", error);
                    }
                });

                var formData = new FormData();

                var beforeFiles = $("#BeforeFileInput")[0].files;
                if (beforeFiles.length === 0) {
                    alert("請選擇 'Before' 檔案！");
                    return;
                }
                for (var i = 0; i < beforeFiles.length; i++) {
                    formData.append("before_files[]", beforeFiles[i]);
                }

                var afterFiles = $("#AfterFileInput")[0].files;
                if (afterFiles.length === 0) {
                    alert("請選擇 'After' 檔案！");
                    return;
                }
                for (var i = 0; i < afterFiles.length; i++) {
                    formData.append("after_files[]", afterFiles[i]);
                }

                let primaryKey = $("#PrimaryKeyInput").val();
                if (!primaryKey) {
                    alert("Primary Key 不能為空");
                    return;
                }
                formData.append("primaryKey", primaryKey);

                $.ajax({
                    url: "/DataProduct/CompareGod_Main",
                    type: "POST",
                    data: formData,
                    contentType: false,
                    processData: false,
                    beforeSend: function () {
                        showLoading("資料比對中");
                    },
                    success: function (response) {
                        if (response.includes(".xlsx")) {
                            $("#DownloadButton")
                                .attr("href", "/DataProduct/CompareGod_DownloadFile?fileName=" + encodeURIComponent(response))
                                .removeClass("disabled")
                                .css("pointer-events", "auto");

                            $("#DownloadButton").click(function() {
                                var downloadLink = document.createElement('a');
                                downloadLink.href = $("#DownloadButton").attr("href");

                                downloadLink.click();

                                $("#DownloadButton")
                                    .attr("href", "#")
                                    .addClass("disabled")
                                    .css("pointer-events", "none");
                            });

                            alert("執行成功");
                        } else {
                            alert("錯誤: " + response);
                            $("#DownloadButton")
                                .attr("href", "#")
                                .addClass("disabled")
                                .css("pointer-events", "none");
                        }
                    },
                    error: function(xhr, status, error) {
                        alert("發生未預期的錯誤");
                        $("#DownloadButton")
                            .attr("href", "#")
                            .addClass("disabled")
                            .css("pointer-events", "none");
                    },
                    complete: function () {
                        hideLoading();
                    }
                });
            });

            $("#DownloadButton").on("click", function (e) {
                e.preventDefault();

                if (!$(this).hasClass("disabled")) {
                    const downloadUrl = $(this).attr("href");
                    const urlParams = new URLSearchParams(downloadUrl.split('?')[1]);
                    const fileName = urlParams.get("fileName");

                    setTimeout(() => {
                        $.ajax({
                            url: "/DataProduct/CompareGod_DeleteFile",
                            type: "POST",
                            data: { fileName: fileName },
                            success: function (res) {
                                console.log("檔案刪除成功");
                            },
                            error: function (err) {
                                console.error("刪除失敗", err);
                            }
                        });
                    }, 1000);
                }
            });
        });
    </script>
}