    <script>
        $(document).ready(function () {
            @*
            $.ajax({
                url: '/Universal/Insert_Usage_Log',
                type: 'POST',
                data: {
                    Tool: '健康報告',
                    Remark: '開啟介面'
                },
                success: function () {
                    console.log("Log Insert Success.");
                },
                error: function (xhr, status, error) {
                    console.error("Error triggering log insertion:", error);
                }
            });
            *@
            // 顯示 loading
            showLoading();

            //
            initPage();

            // 點擊執行更新按鈕後，刷新頁面
            $('#sendDataButton').on('click', function () {
                
                $.ajax({
                    url: '/Universal/Insert_Usage_Log',
                    type: 'POST',
                    data: {
                        Tool: '健康報告',
                        Remark: '執行更新'
                    },
                    success: function () {
                        console.log("Log Insert Success.");
                    },
                    error: function (xhr, status, error) {
                        console.error("Error triggering log insertion:", error);
                    }
                });
                
                $('#sendDataButton').prop('disabled', true);
                showLoading();

                var selectedBrand = $('#brandSelect').val();
                var selectedServer = $('#serverSelect').val();
                var selectedTime = $('#time').val();
                var selectedTime2 = $('#time2').val();
                var excludeGroup = $('#excludeGroup').val();
                var excludeLogin = $('#excludeLogin').val();

                //var [startTime, endTime] = selectedTime.split(" to ").map(time => time.trim());

                if (selectedServer && selectedTime && selectedTime2) {
                    localStorage.setItem('triggerUpdatePosition', 'true');

                    //var newUrl = `ServerHealth?brandselect=${encodeURIComponent(selectedBrand)}&serverselect=${encodeURIComponent(selectedServer)}&time=${encodeURIComponent(selectedTime)}`;

                    var newUrl = `ServerHealth?brandselect=${encodeURIComponent(selectedBrand)}&serverselect=${encodeURIComponent(selectedServer)}&time=${encodeURIComponent(selectedTime)}&endTime=${encodeURIComponent(selectedTime2)}`;

                    // 檢查是否填入 excludeGroup
                    if (excludeGroup) {
                        newUrl += `&excludeGroup=${encodeURIComponent(excludeGroup)}`;
                    }

                    // 檢查是否填入 excludeLogin
                    if (excludeLogin) {
                        newUrl += `&excludeLogin=${encodeURIComponent(excludeLogin)}`;
                    }

                    @*
                    console.log(newUrl);
                    console.log(selectedTime);
                    console.log(selectedTime2);
                    *@
                    window.location.href = newUrl;

                } else {
                    hideLoading();
                    $('#sendDataButton').prop('disabled', false);
                }
            });
        });

        // 初始化葉面 加入active樣式，
        // $('.tab-pane').addClass('show active');
        function initPage() {
            // 加入 active 樣式
            $('.tab-pane').addClass('show active');

            // 初始 DataTable
            @*
            var tables = [
                initializeDataTable('position_datatable', 25),
                initializeDataTable('addorder_datatable'),
                initializeDataTable('socialtrading_datatable'),
                initializeDataTable('hft_datatable_A'),
                initializeDataTable('hft_datatable_B'),
                initializeDataTable('archive_datatable'),
                initializeDataTable('groupticket_datatable', 25)
            ];
            *@
            var table = initializeDataTable('position_datatable', 25);
            var table2 = initializeDataTable('addorder_datatable');
            var table3 = initializeDataTable('socialtrading_datatable');
            var table4 = initializeDataTable('hft_datatable_A');
            var table7 = initializeDataTable('hft_datatable_B');
            var table5 = initializeDataTable('archive_datatable');
            var table6 = initializeDataTable('groupticket_datatable', 25);


            // 自定義篩選條件
            // HFT 表格的篩選條件
            //
            var hftFilterIds = ['#filterclose', '#filtermodify', '#filteropen', '#filterpending', '#filterdelete'];
            var hftValidStatuses = ['close', 'modify', 'open', 'pending', 'delete'];

            // Archive 表格的篩選條件
            var archiveFilterIds = ['#filterlogin', '#filtertrade', '#filterdw', '#filterposped', '#filterbalance', '#filterarchive'];
            var archiveValidStatuses = ['login', 'trade', 'DW', 'position', 'balance', 'achievable'];

            // 添加篩選功能到 HFT 表格
            addCustomFilter('hft_datatable_A', hftFilterIds,3, hftValidStatuses);
            initTableFilters(hftFilterIds, table4);

            // 添加篩選功能到 Archive 表格
            addCustomFilter('archive_datatable', archiveFilterIds,3 ,archiveValidStatuses);
            initTableFilters(archiveFilterIds, table5);


            //時間篩選功能
            generateTimeFilterOptions(table, '#position_timeFilterSelect',6);
            addTimeFilter(table, '#position_timeFilterSelect', 6);

            generateTimeFilterOptions(table2, '#addorder_timeFilterSelect', 8);
            addTimeFilter(table2, '#addorder_timeFilterSelect', 8);

            generateTimeFilterOptions(table3, '#socialtrading_timeFilterSelect', 7);
            addTimeFilter(table3, '#socialtrading_timeFilterSelect', 7);

