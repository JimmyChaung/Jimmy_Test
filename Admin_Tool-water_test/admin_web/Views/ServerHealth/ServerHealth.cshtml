@model admin_web.Models.DataProduct.ServerHealth_ViewModel
@using System.Data
@{
    ViewData["Title"] = "Server Health";
    List<string> fileContent = ViewBag.FileContent as List<string>;
    string FileName = ViewBag.FileName as string;
    var brandlist = ViewBag.Brands as List<string>;
    var serverlist = ViewBag.ServersByBrand as Dictionary<string, List<string>>;

}

<style>
    /* 標題設計 */
    .header-container {
        display: flex; /* 使用 Flexbox 排列子元素 */
        align-items: center; /* 子元素在垂直方向居中 */
        gap: 10px; /* 子元素之間的水平間距 */
    }
    .header-container2 {
        display: flex;
        align-items: center; /* 垂直置中 */
        background: linear-gradient(to right, #a4ebed, #00008b); /* 從淺藍到深藍的漸變 */
        padding: 10px 20px;
        border-radius: 8px;
        margin-bottom: 20px;
    }

    .header-title {
        color: white; /* 白色字體 */
        margin: 0; /* 去掉標題的默認外距 */
        font-family: Arial, sans-serif; /* 字體設置 */
        font-size: 24px; /* 字體大小 */
        flex-grow: 1; /* 讓標題擴展填充剩餘空間 */
    }

    .header-image {
        width: 40px; /* 調整圖片寬度 */
        height: 40px; /* 調整圖片高度 */
        margin-right: 10px; /* 圖片與標題之間的間距 */
    }

    .indicator-header {
        background-color: #87CEEB; /* 淺藍色 # */
        color: white; /* 白色字體 */
        padding: 5px 10px; /* 內距 */
        display: inline-block; /* 使寬度根據內容自適應 */
        border-radius: 5px; /* 邊角圓潤 */
        /*margin-bottom: 15px; /* 與下方內容保持距離 */
        font-size: 1.2em; /* 字體大小 */
        white-space: nowrap; /* 防止自動換行 */
    }

    .chart-container {
        display: flex;
        justify-content: center;
        margin: 20px auto; /* 讓圖表上下都有點間距，並水平居中 */
        width: 80%; /* 根據需要調整寬度 */
    }

    .chart-container2 {
        display: flex;
        justify-content: center;
        margin: 20px auto; /* 讓圖表上下都有點間距，並水平居中 */
        width: 100%; /* 根據需要調整寬度 */
    }

    #navbar-example3 {
        position: fixed; /* 固定在螢幕左側 */
        top: 60px;
        left: 0;
        width: 150px; /* 設置導航欄寬度 */
        height: 430px; /* 讓導航欄佔滿整個頁面的高度 */
        padding: 20px; /* 添加一點內邊距 */
        transition: width 0.3s ease; /* 讓寬度變化時有過渡效果 */
    }

    .nav-link {
        white-space: nowrap; /* 禁止換行 */
    }

    @@media (max-width: 1600px) {
        #navbar-example3 {
            width: 0;
            opacity: 0;
            pointer-events: none;
        }
    }
    .form-check-input.readonly,
    .form-check-label {
        pointer-events: none; /* 禁止互動 */
    }




</style>


<head>
    <meta charset="UTF-8">
    @*<link href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css" rel="stylesheet">*@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-F3w7mX95PdgyTmZZMECAngseQB83DfGTowi0iMjiWaeVhAn4FJkqJByhZMI3AhiU" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/antd@4.23.0/dist/antd.min.css" rel="stylesheet" />
