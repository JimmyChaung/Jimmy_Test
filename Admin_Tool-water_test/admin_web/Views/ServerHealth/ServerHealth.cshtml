        $(document).ready(function () {
            // 顯示模態框
            $('[id^=openModalBtn]').on('click', function () {
                const modalId = $(this).data('modal-id');
                $('.modal-overlay').fadeIn(200); // 顯示背景遮罩
                setTimeout(() => {
                    $(`#${modalId}`).css('display', 'block').addClass('show').removeClass('hide'); // 顯示模態框
                }, 10); // 短暫延遲後再切換 display
            });

            // 隱藏模態框
            function closeModal() {
                $('.modal-overlay').fadeOut(200); // 隱藏背景遮罩
                $('.ant-modal').addClass('hide').removeClass('show');
                setTimeout(function () {
                    $('.ant-modal').css('display', 'none'); // 完全隱藏模態框
                }, 300); // 時間與 CSS 動畫一致
            }

            // 點擊背景遮罩或按鈕關閉模態框
            $('#closeModalBtn, #cancelBtn, .modal-overlay').on('click', function () {
                closeModal();
            });
        });


        document.addEventListener('DOMContentLoaded', function () {
            // 當按鈕被點擊時，打開相對應的模態框
            document.querySelectorAll('button[id^="openModalBtn"]').forEach(button => {
                button.addEventListener('click', function () {
                    const modalId = this.dataset.modalId; // 取得 data-modal-id
                    document.getElementById(modalId).style.display = 'block'; // 顯示對應的模態框
                });
            });

            // 關閉模態框的事件處理
            document.querySelectorAll('.ant-modal-close, #cancelBtn').forEach(button => {
                button.addEventListener('click', function () {
                    const modal = this.closest('.ant-modal'); // 找到最近的模態框
                    if (modal) {
                        modal.style.display = 'none'; // 隱藏模態框
                    }
                });
            });
        });
    </script>
