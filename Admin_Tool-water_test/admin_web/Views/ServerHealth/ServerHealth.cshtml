        <p>Archive Inactivity Period(Disabled): @Model.IndicatorValues.ARCHIVE_INACTIVITY</p>
    }



    <hr>

    <div class="header-container">
        <div id="section1" class="indicator-header" style="scroll-margin-top: 60px;">
            伺服器負載狀況
        </div>

        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#loading_modal">
            <i class="bi bi-question-circle"></i>
        </button>
    </div>
    <!-- Modal -->
    <div class="modal fade" id="loading_modal" tabindex="-1" aria-labelledby="loading_modal_label" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="loading_modal_label">FAQ</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="loadingContent"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">關閉</button>
                    <button type="button" class="btn btn-primary save-content" data-modal="loading_modal">儲存</button>
                </div>
            </div>
        </div>
    </div>



    @if (Model != null && Model.DataList_loading != null && Model.DataList_loading.Rows.Count > 0)
    {
        <table id="loading_datatable" class="table table-striped table-bordered nowrap" hidden="hidden">
            <thead>
                <tr>
                    @foreach (DataColumn column in Model.DataList_loading.Columns)
                    {
                        <th>@column.ColumnName</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (DataRow row in Model.DataList_loading.Rows)
                {
                    <tr>
                        @foreach (var item in row.ItemArray)
                        {
                            <td>@item</td>
                        }
                    </tr>
                }
            </tbody>
        </table>


        <div class="chart-container2" id="loading_chart" style="height: 400px;"></div>

        <script>
        generateloadingChart(@Html.Raw(Model.Data_loading), 'loading_chart');
        </script>


    }
    else
    {
        <p> </p>
    }

    <hr>

    @*position*@

    <div class="header-container">
        <div id="section2" class="indicator-header" style="scroll-margin-top: 60px;">
            單一客戶持倉量 - 指定區間
        </div>
        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#position_modal">
            <i class="bi bi-question-circle"></i>
        </button>
    </div>
    <!-- Modal -->
    <div class="modal fade" id="position_modal" tabindex="-1" aria-labelledby="position_label" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="position_label_label">FAQ</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">

                    <div id="positionContent"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">關閉</button>
                    <button type="button" class="btn btn-primary save-content" data-modal="position_modal">儲存</button>
                </div>
            </div>
        </div>
    </div>



    <div class="content">
        @if (Model != null && Model.DataList_position != null && Model.DataList_position.Rows.Count > 0)
        {

            <select class="form-select" id="position_timeFilterSelect" aria-label="Select a time" style="width: 300px; margin-top: 20px; ">
                <option value="" selected>---All---</option>
            </select>

            <div class="chart-container" id="position_chart" style="height: 400px;"></div>

            <table id="position_datatable" class="table table-striped table-bordered nowrap">
                <thead>
                    <tr>
                        @foreach (DataColumn column in Model.DataList_position.Columns)
                        {
                            <th>@column.ColumnName</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (DataRow row in Model.DataList_position.Rows)
