                //<option value="@brand">@brand</option>
                if (ViewBag.selectedbrand == brand)
                {
                    <option value="@brand" selected>@brand</option>
                }
                else
                {
                    <option value="@brand">@brand</option>
                }

            }
        </select>

        @*<-- 伺服器選單 -->*@
        <select id="serverSelect" name="serverSelect" class="form-select" style="width: 150px; margin-right: 20px;">
            <option value=""></option>
        </select>

        @*<-- 表單，用於提交選擇的伺服器 -->*@
        @*<-- 日期選擇器 -->*@
        <h3>日期：</h3>
        @*<input type="datetime-local" id="time" name="time" class="form-control" value="2024-09-16T12:30" style="width: 300px;" />*@
        <input type="text" id="time" class="form-control" placeholder="選擇時間1" style="width: 180px;">
        <input type="text" id="time2" class="form-control" placeholder="選擇時間2" style="width: 180px;">


        @*<button type="submit" id="sendDataButton" class="btn btn-outline-primary">執行更新</button>*@

