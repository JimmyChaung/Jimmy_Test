    @if (Model != null && Model.DataList_configuration != null && Model.DataList_configuration.Rows.Count > 0)
    {
        <script>
                // 從後端的 DataList_configuration 將資料轉換為 JavaScript 物件
                updateCheckBoxes(@Html.Raw(Model.Data_configuration));
        </script>

    }


    <hr>

    <div class="header-container">
        <div id="section9" class="indicator-header" style="scroll-margin-top: 60px;">
            伺服器分析 (EOD)
        </div>

        <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#Indicator_modal">
            <i class="bi bi-question-circle"></i>
        </button>
    </div>

    <!-- Modal -->
    <div class="modal fade" id="Indicator_modal" tabindex="-1" aria-labelledby="Indicator_modal_label" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="Indicator_modal_label">FAQ</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="indicatorContent"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">關閉</button>
                    <button type="button" class="btn btn-primary save-content" data-modal="Indicator_modal">儲存</button>
                </div>
            </div>
        </div>
    </div>
    <button type="button" class="btn btn-primary btn-sm d-none" data-bs-toggle="modal" data-bs-target="#view_Indicator_modal">
        <i class="bi bi-patch-question"></i>
    </button>

    <!-- Modal -->
    <div class="modal fade" id="view_Indicator_modal" tabindex="-1" aria-labelledby="view_Indicator_modal_label" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="view_Indicator_modal_label">FAQ</h5>
