    <script>
    // 將 serverlist 從後端傳遞到前端
    var serverList = @Html.Raw(Json.Serialize(serverlist));

    document.addEventListener('DOMContentLoaded', function () {
        var selectedBrand = document.getElementById('brandSelect').value;
        if (selectedBrand) {
            populateServers(selectedBrand); // 自動填充伺服器選項
        }
    });

    // 品牌變更時，填充伺服器選項
    document.getElementById('brandSelect').addEventListener('change', function () {
        var selectedBrand = this.value;
        populateServers(selectedBrand); // 更新伺服器選單
    });

    function populateServers(selectedBrand) {
        var serverSelect = document.getElementById('serverSelect');
        serverSelect.innerHTML = '<option value="">選擇伺服器</option>'; // 清空伺服器選單

        if (selectedBrand && serverList[selectedBrand]) {
            var servers = serverList[selectedBrand]; // 使用Script中的serverList
            var selectedServer = '@ViewBag.selectedserver'; // 頁面中已選的伺服器

            servers.forEach(function (server) {
                var option = document.createElement('option');
                option.value = server;
                option.text = server;

                // 保持伺服器選項的選中狀態
                if (server === selectedServer) {
                    option.selected = true;
                }

                serverSelect.appendChild(option);
            });
        }
    }
    </script>


    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var urlParams = new URLSearchParams(window.location.search);

            // 初始化開始時間選擇器 (#time)
            flatpickr('#time', {
                enableTime: true, // 啟用時間選擇
                dateFormat: "Y-m-d H:i", // 設置日期和時間的格式
                time_24hr: true, // 啟用24小時制
                defaultDate: (function () {
                    var startTime = urlParams.get('time'); // 獲取 URL 中的開始時間
                    if (startTime) {
                        return startTime; // 使用指定的開始時間
                    } else {
                        var currentDate = new Date();
                        currentDate.setHours(currentDate.getHours() - 7); // 默認開始時間
                        return currentDate.toISOString().slice(0, 16).replace('T', ' ');
                    }
                })()
            });

            // 初始化結束時間選擇器 (#time2)
            flatpickr('#time2', {
                enableTime: true, // 啟用時間選擇
                dateFormat: "Y-m-d H:i", // 設置日期和時間的格式
                time_24hr: true, // 啟用24小時制
                defaultDate: (function () {
                    var endTime = urlParams.get('endTime'); // 獲取 URL 中的結束時間
                    if (endTime) {
                        return endTime; // 使用指定的結束時間
                    } else {
                        var currentDate = new Date();
                        currentDate.setHours(currentDate.getHours() - 4); // 默認結束時間
                        return currentDate.toISOString().slice(0, 16).replace('T', ' ');
                    }
                })()
            });

            // 設置其他輸入框默認值
            $('#excludeGroup').val(urlParams.get('excludeGroup') || '');
            $('#excludeLogin').val(urlParams.get('excludeLogin') || '');
        });

    </script>


