            <label class="form-check-label" for="BASIC_ACCOUNTCheckbox">基本帳戶</label>
        </div>
        <div class="form-check d-inline-block me-3">
            <input class="form-check-input readonly" type="checkbox" id="USCCheckbox">
            <label class="form-check-label" for="USCCheckbox">美分帳戶</label>
        </div>
        <div class="form-check d-inline-block me-3">
            <input class="form-check-input readonly" type="checkbox" id="SGCheckbox">
            <label class="form-check-label" for="SGCheckbox">特殊組別</label>
        </div>
        <div class="form-check d-inline-block me-3">
            <input class="form-check-input readonly" type="checkbox" id="SCCheckbox">
            <label class="form-check-label" for="SCCheckbox">特殊幣種</label>
        </div>

