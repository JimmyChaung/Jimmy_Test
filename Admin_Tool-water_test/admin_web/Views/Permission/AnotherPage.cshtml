<style>

    /* 基本按鈕樣式 */
    .button-container {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        border-bottom: 1px solid #ccc;
    }

    .edit-btn, .delete-btn {
        font-size: 18px;
        font-weight: bold;
        cursor: pointer;
        text-decoration: none;
    }

    /* 編輯按鈕樣式 */
    .edit-btn {
        color: #333; /* 黑色 */
    }

    /* 刪除按鈕樣式 */
    .delete-btn {
        color: #FF4500; /* 橘紅色 */
    }

    /* hover 效果 */
    .edit-btn:hover {
        color: #666;
    }

    .delete-btn:hover {
        color: #FF6347; /* 更亮的橘紅色 */
    }

    .search-input {
        background: url('https://cdn.jsdelivr.net/npm/bootstrap-icons/icons/search.svg') no-repeat right 10px center;
        background-size: 16px;
        padding-right: 30px; /* 調整內邊距，避免文字和圖示重疊 */
    }

    .icon-large-red-background {
        background-color: white; /* 紅色背景 */
        color: red; /* 圖示顏色設為白色 */
        padding: 8px; /* 內邊距讓背景更大 */
        border-radius: 5px; /* 添加圓角 */
        font-size: 5rem; /* 調整圖示大小 */
        display: inline-flex; /* 讓背景與圖示大小一致 */
        align-items: center; /* 置中對齊圖示 */
        justify-content: center; /* 置中對齊圖示 */
    }


    .modal-content {
        border: none; /* 去掉模态框边框 */
        border-radius: 0; /* 去掉圆角 */
    }

    .modal-header {
        display: none; /* 隐藏标题 */
    }

    .modal-body {
        border-bottom: none; /* 去掉底部边框 */
        padding-bottom: 0; /* 去掉底部内边距 */
    }

    .modal-footer {
        border-top: none;
        border-top: none !important; /* 移除 modal-footer 上部邊框 */

        border: none; /* 去掉底部线 */
        display: flex;
        justify-content: center; /* 底部按钮居中 */
        padding-top: 0; /* 去掉顶部内边距 */
        margin-top: 0; /* 去掉顶部外边距 */
    }

        .modal-footer .btn {
            margin: 0 5px; /* 按钮之间添加少量间距 */
        }



    .dropdown-menu {
        max-height: 300px;
        overflow-y: auto;
        width: 100%;
    }

    .dropdown-item input[type="checkbox"] {
        margin-right: 8px;
    }

    .dropdown-divider {
        padding: 0;
        margin: 0;
    }

    .dropdown-header {
        font-weight: bold;
        font-size: 0.9rem;
        color: #6c757d;
        padding-top: 8px;
        padding-bottom: 4px;
    }

    .dropdown-toggle {
        width: 100%;
        max-width: 200px;
        text-overflow: ellipsis;
        overflow: hidden;
        white-space: nowrap;
    }
</style>

