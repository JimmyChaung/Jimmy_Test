<script>
    // Select all functionality
    document.getElementById('selectAll').addEventListener('change', function () {
        const checkboxes = document.querySelectorAll('.dropdown-menu input[type="checkbox"]:not(#selectAll)');
        checkboxes.forEach(checkbox => checkbox.checked = this.checked);
        updateButtonText();
    });

    // Update button text based on selected options
    document.querySelectorAll('.dropdown-menu input[type="checkbox"]').forEach(function (checkbox) {
        checkbox.addEventListener('change', function () {
            if (this.id !== 'selectAll') {
                document.getElementById('selectAll').checked = Array.from(document.querySelectorAll('.dropdown-menu input[type="checkbox"]:not(#selectAll)')).every(input => input.checked);
            }
            updateButtonText();
        });
    });

    function updateButtonText() {
        const selectedOptions = [];
        document.querySelectorAll('.dropdown-menu input[type="checkbox"]:checked:not(#selectAll)').forEach(function (selected) {
            selectedOptions.push(selected.value);
        });

        // If the number of selected options exceeds a certain limit, show the count
        const maxLength = 3; // Adjust this value to control when to switch to count
        const button = document.getElementById('dropdownButton');

        if (selectedOptions.length > maxLength) {
            button.textContent = `Selected: ${selectedOptions.length} items`;
        } else {
            button.textContent = selectedOptions.length > 0
                ? `Selected: ${selectedOptions.join(', ')}`
                : 'Select...';
        }
    }
</script>