<!-- Confirm Activation/Deactivation modal -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-body text-center">
                <!-- <i class="bi bi-exclamation-triangle-fill icon-large-red-background" style="font-size: 50px; color: red;"></i> -->
                <i id="exclamationIcon" class="bi bi-exclamation-circle-fill" style="font-size: 50px; color: red;"></i>

                <h3 id="modalTitle">此操作將影響此帳號使用</h3>
                <h6 id="modalMessage">您確定要進行此操作嗎?</h6>
            </div>
            <div class="modal-footer" style="display: flex; justify-content: center;">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" onclick="cancelAction()">取消</button>
                <button type="button" id="confirmButton" class="btn" data-bs-dismiss="modal" onclick="confirmAction()">確定</button>
            </div>
        </div>
    </div>
</div>






<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="~/js/popper.min.js"></script>
<script>

    $(document).ready(function () {
        let toggleSwitch = document.getElementById('toggleSwitch');
        let isCheckedInitially;

        function showConfirmModal() {
            isCheckedInitially = toggleSwitch.checked;

            const confirmButton = document.getElementById("confirmButton");
            const exclamationIcon = document.getElementById("exclamationIcon");

            if (isCheckedInitially) {
                document.getElementById("modalTitle").innerText = "該操作將影響此帳號使用";
                document.getElementById("modalMessage").innerText = "您確定要啟用此帳號嗎？";
                confirmButton.classList.remove("btn-danger");
                confirmButton.classList.add("btn-primary");
                exclamationIcon.style.color = "blue";

            } else {
                document.getElementById("modalTitle").innerText = "該操作將影響此帳號使用";
                document.getElementById("modalMessage").innerText = "您確定要停用此帳號嗎？";
                confirmButton.classList.remove("btn-primary");
                confirmButton.classList.add("btn-danger");
                exclamationIcon.style.color = "red";

            }

            $('#confirmModal').modal('show');
            toggleSwitch.checked = !toggleSwitch.checked;
        };

        function confirmAction() {
            toggleSwitch.checked = isCheckedInitially;

            if (toggleSwitch.checked) {
                alert("帳號已啟用！");
            } else {
                alert("帳號已停用！");
            }
        };

        function cancelAction() {
            toggleSwitch.checked = !isCheckedInitially;
        }

        window.showConfirmModal = showConfirmModal;
        window.confirmAction = confirmAction;
        window.cancelAction = cancelAction;
    });


</script>

<script>
    let currentSortColumn = -1;
    let ascending = true;

    function sortTable(columnIndex) {
        const table = document.querySelector("table tbody");
        const rows = Array.from(table.rows);
        const headers = document.querySelectorAll("th");

        // 重置所有欄位的排序圖示
        headers.forEach(header => {
            const sortIcon = header.querySelector(".sort-icon");
            if (sortIcon) {
                sortIcon.textContent = "▼"; // 設為初始狀態
            }
        });

        // 切換排序方向
        if (currentSortColumn === columnIndex) {
            ascending = !ascending;
        } else {
            currentSortColumn = columnIndex;
            ascending = true;
        }

        // 更新當前欄位的排序圖示
        const currentHeader = headers[columnIndex];
        const currentSortIcon = currentHeader.querySelector(".sort-icon");
        if (currentSortIcon) {
            currentSortIcon.textContent = ascending ? "▲" : "▼";
        }

        // 排序邏輯
        rows.sort((a, b) => {
            const aText = a.cells[columnIndex].textContent.trim();
            const bText = b.cells[columnIndex].textContent.trim();
            const isNumeric = !isNaN(aText) && !isNaN(bText);

            if (isNumeric) {
                return ascending ? aText - bText : bText - aText;
            } else {
                return ascending
                    ? aText.localeCompare(bText, 'zh-Hant-TW')
                    : bText.localeCompare(aText, 'zh-Hant-TW');
            }
        });

        // 重新渲染表格內容
        table.append(...rows);
    }
</script>


