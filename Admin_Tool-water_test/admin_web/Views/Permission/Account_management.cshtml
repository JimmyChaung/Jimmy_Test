<!-- Confirm Activation/Deactivation modal -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-body text-center">
                <!-- <i class="bi bi-exclamation-triangle-fill icon-large-red-background" style="font-size: 50px; color: red;"></i> -->
                <i id="exclamationIcon" class="bi bi-exclamation-circle-fill" style="font-size: 50px; color: red;"></i>

                <h3 id="modalTitle">此操作將影響此帳號使用</h3>
                <h6 id="modalMessage">您確定要進行此操作嗎?</h6>
            </div>
            <div class="modal-footer" style="display: flex; justify-content: center;">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" onclick="cancelAction()">取消</button>
                <button type="button" id="confirmButton" class="btn" data-bs-dismiss="modal" onclick="confirmAction('account_enable','editModal_@count_mod')">確定</button>
            </div>
        </div>
    </div>
</div>


<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="~/js/popper.min.js"></script>
<script>

    let isCheckedInitially;
    let globalTrId;
    let globalUserId;

    function showConfirmModal(tr_Id, userId) {
        // 設定全域變數以供其他函數使用
        globalTrId = tr_Id;
        globalUserId = userId;

        // 取得特定用戶的開關
        let toggleSwitch = document.querySelector(`#${tr_Id} #${userId}`);
        isCheckedInitially = toggleSwitch.checked;

        const confirmButton = document.getElementById("confirmButton");
        const exclamationIcon = document.getElementById("exclamationIcon");

        if (isCheckedInitially) {
            document.getElementById("modalTitle").innerText = "該操作將影響此帳號使用";
            document.getElementById("modalMessage").innerText = "您確定要啟用此帳號嗎？";
            confirmButton.classList.remove("btn-danger");
            confirmButton.classList.add("btn-primary");
            exclamationIcon.style.color = "blue";

        } else {
            document.getElementById("modalTitle").innerText = "該操作將影響此帳號使用";
            document.getElementById("modalMessage").innerText = "您確定要停用此帳號嗎？";
            confirmButton.classList.remove("btn-primary");
            confirmButton.classList.add("btn-danger");
            exclamationIcon.style.color = "red";
        }
        // 顯示確認彈窗
        $('#confirmModal').modal('show');
    }

    $('#confirmModal').on('hidden.bs.modal', function () {

        // 根據初始開關狀態切換開關
        let toggleSwitch = document.querySelector(`#${globalTrId} #${globalUserId}`);
        if (toggleSwitch) {
            // 如果是初始啟用狀態，則將開關設為禁用，反之亦然
            toggleSwitch.checked = !isCheckedInitially;
        }
    });

    async function confirmAction(con_type, modal_con) {

        if (con_type == 'account_enable') {
            // 取得目前使用者的開關
            let toggleSwitch = document.querySelector(`#${globalTrId} #${globalUserId}`);
            if (!toggleSwitch) return;

            // 恢復原始開關狀態
            toggleSwitch.checked = isCheckedInitially;

            // 簡化的取值函數
            function getElementText(trId, suffix) {
                const element = document.querySelector(`#${trId} #${suffix}`);
                return element ? element.textContent : null; // 確保元素存在後返回內容
            }

            // 使用該函數來取得各欄位的值
            const trId = globalTrId; // 假設 globalTrId 已設置為當前 tr 的 ID
            const tr_con = globalTrId.split('_')[1]; // 假設 tr_con 是當前行的數字

            const loginValue = getElementText(trId, `Login_${tr_con}`);
            const nameValue = getElementText(trId, `Name_${tr_con}`);
            const roleValue = getElementText(trId, `Role_${tr_con}`);
            const emailValue = getElementText(trId, `Email_${tr_con}`);
            const lastTimeValue = getElementText(trId, `Last_Time_${tr_con}`);
            const user_enable = toggleSwitch.checked ? "1" : "0"; // "1" 表示啟用, "0" 表示停用

            //console.log(loginValue, nameValue, roleValue, emailValue, lastTimeValue, user_enable); // 顯示取得的值
            const status = toggleSwitch.checked ? "啟用" : "停用";

            // 發送資料到後端 Controller
            try {
                const response = await fetch('/Permission/Account_management', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ loginValue, nameValue, roleValue, emailValue, lastTimeValue, status })
                });

                if (response.ok) {
                    const result = await response.text(); // 假設回傳的是部分視圖的 HTML
                    // 更新主視圖中的部分視圖容器
                    document.getElementById('content-area').innerHTML = result;
                    // 刪除當前頁面的所有 <script> 標籤
                    $('script').each(function () {
                        this.remove();
                    });
                    // 重新加載當前頁面上的所有JS
                    $('head').append($('script[src]'));  // 重新將所有JS加入頁面
                }
                else {
                    console.log("error")
                }
            }
            catch (error) {
            }
            finally {
                // 關閉模態框
                $(`#${modal_con}`).modal('hide');
                $('.modal-backdrop').remove();  // 移除背景遮罩層
            }
        }
        else if (con_type == 'account_edit') {
            //const trId = globalTrId; // 假設 globalTrId 已設置為當前 tr 的 ID
            const tr_con = modal_con.split('_')[1]; // 假設 tr_con 是當前行的數字

            //editLogin_2
            loginValue = document.querySelector(`#${modal_con} #editLogin_${tr_con}`).value;
            nameValue = document.querySelector(`#${modal_con} #editName_${tr_con}`).value;
            roleValue = document.querySelector(`#${modal_con} #selected-role_${tr_con}`).value;
            emailValue = document.querySelector(`#${modal_con} #editEmail_${tr_con}`).value;
            user_enable = document.querySelector(`#${modal_con} #editenable_${tr_con}`).value;

            console.log(`#${modal_con} #selected-role_${tr_con}`);
            console.log(loginValue, nameValue, roleValue, emailValue, user_enable);
            // 發送資料到後端 Controller
            try {
                const response = await fetch('/Permission/Account_management', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ loginValue, nameValue, roleValue, emailValue, user_enable })
                });

                if (response.ok) {
                    const result = await response.text(); // 假設回傳的是部分視圖的 HTML
                    // 更新主視圖中的部分視圖容器
                    document.getElementById('content-area').innerHTML = result;
                    // 刪除當前頁面的所有 <script> 標籤
                    $('script').each(function () {
                        this.remove();
                    });
                    // 重新加載當前頁面上的所有JS
                    $('head').append($('script[src]'));  // 重新將所有JS加入頁面
                } else {
                    console.log("error");
                }
            } catch (error) {
                console.error("發送請求出錯:", error);
            } finally {
                // 關閉模態框
                $(`#${modal_con}`).modal('hide');
                $('.modal-backdrop').remove();  // 移除背景遮罩層
            }

        }
    }

    function cancelAction() {
        // 使用全域變數取得目前使用者的開關
        let toggleSwitch = document.querySelector(`#${globalTrId} #${globalUserId}`);
        if (!toggleSwitch) return;
        // 切換開關的狀態
        toggleSwitch.checked = !isCheckedInitially;
        const status = toggleSwitch.checked ? "啟用" : "停用";
        // 關閉彈窗
        $('#confirmModal').modal('hide');
    }


    $(document).on('click', '.confirm-delete', async function () {

        const accountId = $(this).data('id'); // 根據實際需求取得相關資料
        console.log(typeof accountId);

        try {
            const response = await fetch('/Permission/DeleteAccount', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(accountId)
            });

            if (response.ok) {
                const result = await response.text();
                document.getElementById('content-area').innerHTML = result;
                console.log('刪除成功');
                // 刪除當前頁面的所有 <script> 標籤
                $('script').each(function () {
                    this.remove();
                });
                // 重新加載當前頁面上的所有JS
                $('head').append($('script[src]'));  // 重新將所有JS加入頁面
            } else {
                console.log("error log");
            }
        } catch (error) {
            console.error('發送請求時發生錯誤:', error);
        }
    });





</script>

<script>
    async function add_account() {
        console.log("addAccountBtn");
        const Login = document.getElementById('Login').value;
        const Name = document.getElementById('Name').value;
        const Email = document.getElementById('Email').value;
        const Role = document.getElementById('role-select_0').value;

        console.log("add is ok");
        console.log(Login, Name, Email, Role);

        // 檢查表單是否完整
        if (!Login || !Name || !Email || !Role) {
            console.log("請完整填寫表單！");
            return;
        }

        try {
            console.log("start");
            const response = await fetch('/Permission/AddAccount', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ LoginValue: Login, NameValue: Name, EmailValue: Email, RoleValue: Role }),
            });

            if (response.ok) {
                const result = await response.text();
                document.getElementById('content-area').innerHTML = result; // 更新部分視圖
                $('#exampleModal').modal('hide'); // 使用 jQuery 來隱藏模態框
                $('.modal-backdrop').remove();  // 移除背景遮罩層

            } else {
                console.log("error log")
            }
        } catch (error) {
            console.error("新增帳號時發生錯誤:", error);
        } finally {
            $('.modal-backdrop').remove();  // 移除背景遮罩層

        }

    };



    async function Search_table() {
        const searchInput = document.getElementById("exampleDataList").value.toLowerCase();
        const selectedRole = document.getElementById("Role_00").value.toLowerCase();
        const table = document.getElementById("table_all");
        const rows = table.querySelectorAll("tbody tr");

        //2,一般使用者、table、list
        console.log(searchInput, selectedRole, table, rows);
        // 遍歷每一行，根據條件顯示或隱藏
        rows.forEach(row => {
            const login = row.querySelector(`#${row.id} td:nth-child(1)`).textContent.toLowerCase();
            const role = row.querySelector(`#${row.id} td:nth-child(3)`).textContent.toLowerCase();

            // 確定是否匹配
            const matchesLogin = !searchInput || login.includes(searchInput);
            const matchesRole = selectedRole === "all" || role.includes(selectedRole);

            if (matchesLogin && matchesRole) {
