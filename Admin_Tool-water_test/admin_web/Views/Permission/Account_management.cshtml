@{
    ViewData["Title"] = "帳號管理";
}

<style>
    /* 基本按鈕樣式 */
    .button-container {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        border-bottom: 1px solid #ccc;
    }

    .edit-btn, .delete-btn {
        font-size: 18px;
        font-weight: bold;
        cursor: pointer;
        text-decoration: none;
    }

    /* 編輯按鈕樣式 */
    .edit-btn {
        color: #333; /* 黑色 */
    }

    /* 刪除按鈕樣式 */
    .delete-btn {
        color: #FF4500; /* 橘紅色 */
    }

    /* hover 效果 */
    .edit-btn:hover {
        color: #666;
    }

    .delete-btn:hover {
        color: #FF6347; /* 更亮的橘紅色 */
    }

    .search-input {
        background: url('https://cdn.jsdelivr.net/npm/bootstrap-icons/icons/search.svg') no-repeat right 10px center;
        background-size: 16px;
        padding-right: 30px; /* 調整內邊距，避免文字和圖示重疊 */
    }

    .icon-large-red-background {
        background-color: white; /* 紅色背景 */
        color: red; /* 圖示顏色設為白色 */
        padding: 8px; /* 內邊距讓背景更大 */
        border-radius: 5px; /* 添加圓角 */
        font-size: 5rem; /* 調整圖示大小 */
        display: inline-flex; /* 讓背景與圖示大小一致 */
        align-items: center; /* 置中對齊圖示 */
        justify-content: center; /* 置中對齊圖示 */
    }


    .modal-content {
        border: none; /* 去掉模态框边框 */
        border-radius: 0; /* 去掉圆角 */
    }

    .modal-header {
        display: none; /* 隐藏标题 */
    }

    .modal-body {
        border-bottom: none; /* 去掉底部边框 */
        padding-bottom: 0; /* 去掉底部内边距 */
    }

    .modal-footer {
        border-top: none;
        border-top: none !important; /* 移除 modal-footer 上部邊框 */

        border: none; /* 去掉底部线 */
        display: flex;
        justify-content: center; /* 底部按钮居中 */
        padding-top: 0; /* 去掉顶部内边距 */
        margin-top: 0; /* 去掉顶部外边距 */
    }

        .modal-footer .btn {
            margin: 0 5px; /* 按钮之间添加少量间距 */
        }



    /* 自訂的切換開關樣式 */
    .switch {
        position: relative;
        display: inline-block;
        width: 60px;
        height: 34px;
    }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }


    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: .4s;
        border-radius: 34px;
    }

        .slider:before {
            position: absolute;
            content: "";
            height: 26px;
            width: 26px;
            left: 4px;
            bottom: 4px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

    input:checked + .slider {
        background-color: #007bff;
    }

        input:checked + .slider:before {
            transform: translateX(26px);
        }
    /* 滑動球啟用藍色效果 */
    .slider:active:before {
        background-color: #1E90FF;
    }

    .sort-icon {
        cursor: pointer;
        margin-left: 5px;
    }
</style>

<script src="~/js/popper.min.js"></script>
<script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>


<div style="display: flex; gap: 10px; align-items: center;">
    <span>
        <input class="form-control search-input" list="datalistOptions" id="exampleDataList" placeholder="帳號搜尋" style="width: 300px;">
        <datalist id="datalistOptions">
            @* for *@
            @foreach (var user in Model)
            {
                <option value="@user.Login">@user.Login</option>
            }
        </datalist>
    </span>

    <span>
        <select class="form-select" style="width: 200px;" id="Role_00">
            <option selected>ALL</option>
            @{ HashSet<string> seenLogins = new HashSet<string>(); }
            @foreach (var user in Model)
            {
                if (!seenLogins.Contains(user.Role))
                {
                    <option value="@user.Role">@user.Role</option>
                    seenLogins.Add(user.Role);
                }
            }
        </select>
        <input type="text" class="form-control" id="selected-role_00" value="ALL" style="display: none;" readonly>
    </span>
    <span>
        <button class="btn btn-primary" style="width: 100px; height: 40px; font-size: 16px;" onclick="Search_table()">Search</button>
    </span>
</div>
<br />



<div style="display: flex; gap: 10px; align-items: center;">
    <span>
        <button class="btn btn-primary" style="width: 130px; height: 40px; font-size: 16px;" data-bs-toggle="modal" data-bs-target="#exampleModal">
            <i class="bi bi-plus-lg"></i> 新增帳號
        </button>
    </span>
</div>



@* detail *@

<table class="table" id="table_all">
    <thead>
        <tr>
            <th scope="col" onclick="sortTable(0)">ID <span class="sort-icon">▼</span></th>
            <th scope="col" onclick="sortTable(1)">暱稱 <span class="sort-icon">▼</span></th>
            <th scope="col" onclick="sortTable(2)">角色管理 <span class="sort-icon">▼</span></th>
            <th scope="col" onclick="sortTable(3)">Email <span class="sort-icon">▼</span></th>
            <th scope="col" onclick="sortTable(4)">最後登入 <span class="sort-icon">▼</span></th>
            <th scope="col">帳號啟用</th>
            <th scope="col">編輯區</th>
        </tr>
    </thead>
    <tbody>
        @{
            var counter = 1;// Create a variable with @ and initialize it
        }


        @foreach (var user in Model)
        {
            <tr id="tr_@counter">
                <td id="Login_@counter">@user.Login</td>
                <td id="Name_@counter">@user.Name</td>
                <td id="Role_@counter">@user.Role</td>
                <td id="Email_@counter">@user.Email</td>
                <td id="Last_Time_@counter">@user.Last_Time</td>

                <td>
                    @if (@user.Enable == 1)
                    {
                        <!-- 有勾選的開關 -->
                        <label class="switch">
                            <input type="checkbox" c id="toggleSwitch_@counter" class="status-checkbox" checked onclick="showConfirmModal('tr_@counter','toggleSwitch_@counter')">
                            <span class="slider"></span>
                        </label>
                    }
                    else
                    {
                        <label class="switch">
                            <input type="checkbox" id="toggleSwitch_@counter" class="status-checkbox" onclick="showConfirmModal('tr_@counter','toggleSwitch_@counter')">
                            <span class="slider"></span>
                        </label>
                    }
                </td>
                <td>
                    <span>
                        <span class="edit-btn" id="Edit_@counter" data-bs-toggle="modal" data-bs-target="#editModal_@counter">編輯</span>
                        <span class="confirm-delete" style="cursor: pointer; color:red;" data-id="@user.Login">刪除</span>
                    </span>
                </td>
            </tr>
            counter++;
        }
    </tbody>
</table>

@{
    var count_mod = 1;// Create a variable with @ and initialize it
}

@foreach (var user in Model)
{
    <!-- edit account modal-->
    <div class="modal fade" id="editModal_@count_mod" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">

        <div class="modal-dialog">
