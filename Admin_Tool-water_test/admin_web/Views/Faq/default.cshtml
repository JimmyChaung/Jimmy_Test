@{ 
    string Name = ViewBag.Name as string;
    string Content = ViewBag.Content as string;
}

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="https://cdn.ckeditor.com/ckeditor5/43.2.0/ckeditor5.css" />
</head>

<body>
    @if (@Name.Length > 0)
    {
        <form id="update-faq-form" method="post">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom:10px;">
                <div id="faq-page-title">@Name</div>
                <div class="btn-group" role="group">
                    <button class="btn btn-outline-primary" type="submit">Submit</button>
                    <button class="btn btn-outline-primary" type="button" onclick="location.reload();">Cancel</button>
                </div>
            </div>

            <input type="hidden" name="ID" value="@ViewBag.Tool_Id" />

            <textarea id="editor" name="Content">@Content</textarea>
        </form>
    }

    <script type="importmap">
        {
            "imports": {
                "ckeditor5": "https://cdn.ckeditor.com/ckeditor5/43.2.0/ckeditor5.js",
                "ckeditor5/": "https://cdn.ckeditor.com/ckeditor5/43.2.0/"
            }
        }
    </script>

    <script type="module">
        import {
            ClassicEditor,
            Alignment,
            Autoformat,
            Bold,
            Italic,
            Underline,
            BlockQuote,
            Base64UploadAdapter,
            CloudServices,
            Essentials,
            Font,
            Heading,
            HorizontalLine,
            Image,
            ImageCaption,
            ImageInsert,
            ImageResize,
            ImageStyle,
            ImageToolbar,
            ImageUpload,
            SimpleUploadAdapter,
            SpecialCharacters,
            SpecialCharactersEssentials,
            Strikethrough,
            PictureEditing,
            Indent,
            IndentBlock,
            Link,
            List,
            Mention,
            Paragraph,
            PasteFromOffice,
            Table,
            TableCellProperties,
            TableColumnResize,
            TableProperties,
            TableToolbar,
            TextTransformation,
        } from 'ckeditor5';

        ClassicEditor
            .create(document.querySelector('#editor'), {
                plugins: [
                    Alignment,
                    Autoformat,
                    Base64UploadAdapter,
                    BlockQuote,
                    Bold,
                    CloudServices,
                    Essentials,
                    Font,
                    Heading,
                    HorizontalLine,
                    Image,
                    ImageCaption,
                    ImageInsert,
                    ImageResize,
                    ImageStyle,
                    ImageToolbar,
                    ImageUpload,
                    SimpleUploadAdapter,
                    SpecialCharacters,
                    SpecialCharactersEssentials,
                    Strikethrough,
                    Indent,
                    IndentBlock,
                    Italic,
                    Link,
                    List,
                    Mention,
                    Paragraph,
                    PasteFromOffice,
                    PictureEditing,
                    Table,
                    TableCellProperties,
                    TableColumnResize,
                    TableProperties,
                    TableToolbar,
                    TextTransformation,
                    Underline,
                ],
                toolbar: [
                    'undo', 'redo', '|',
                    'heading', 'fontSize', 'fontFamily', 'fontColor', 'fontBackgroundColor', "|",
                    'bold', 'italic', 'underline', 'strikethrough','|',
                    @*"outdent", "indent",*@ "alignment", '|',                    
                    "link", "insertImage", "insertTable", 'specialCharacters', "blockQuote", "horizontalLine", "|",
                    "bulletedList", "numberedList",
                ],
                fontSize: {
                    options: [
                        12, 14, 16, 18, 20, 22, 24, 26, 28, 36, 48
                    ],
                    supportAllValues: true
                },
                heading: {
                    options: [
                        {
                            model: 'paragraph',
                            title: 'Paragraph',
                            class: 'ck-heading_paragraph',
                        },
                        {
                            model: 'heading1',
                            view: 'h1',
                            title: 'Heading 1',
                            class: 'ck-heading_heading1',
                        },
                        {
                            model: 'heading2',
                            view: 'h2',
                            title: 'Heading 2',
                            class: 'ck-heading_heading2',
                        },
                        {
                            model: 'heading3',
                            view: 'h3',
                            title: 'Heading 3',
                            class: 'ck-heading_heading3',
                        },
                        {
                            model: 'heading4',
                            view: 'h4',
                            title: 'Heading 4',
                            class: 'ck-heading_heading4',
                        },
                    ],
                },
                image: {
                    toolbar: [
                        'imageTextAlternative',
                        'toggleImageCaption',
                        '|',
                        'imageStyle:inline',
                        'imageStyle:breakText',
                        'imageStyle:wrapText',
                    ],
                },
                table: {
                    contentToolbar: [
                        'tableColumn', 'tableRow', 'mergeTableCells',
                        'tableProperties', 'tableCellProperties'
                    ],
                },
                link: {
                    addTargetToExternalLinks: true,
                    defaultProtocol: 'https://',
                }
            })
            .then(editor => {
                console.log('Editor was initialized', editor);
                // editor.enableReadOnlyMode('#editor');
                // editor.ui.view.editable.element.style.height = 'auto';
                // editor.ui.view.editable.element.style.maxHeight = '700px';
                // editor.ui.view.editable.element.style.overflow = 'auto';
            })
            .catch(error => {
                console.error(error);
            });
    </script>

    <script>
    $(document).ready(function () {
        $('#update-faq-form').on('submit', function (event) {
            event.preventDefault();

            const password = prompt("請輸入密碼：");

            if (!password) {
                alert("密碼未輸入，操作已取消。");
                return;
            }

            $.ajax({
                type: 'POST',
                url: '@Url.Action("ValidatePassword", "Faq")',
                data: { password: password },
                success: function (response) {
                    if (response === 'VALID') {
                        $.ajax({
                            type: 'POST',
                            url: '@Url.Action("Update_Faq", "Faq")',
                            data: $('#update-faq-form').serialize(),
                            success: function (result) {
                                if (result === 'SUCCESS') {
                                    alert("更新成功");
                                    location.reload();
                                } else {
                                    alert(result);
                                }
                            },
                            error: function () {
                                alert('提交失敗，請稍後再試。');
                            }
                        });
                    } else {
                        alert("密碼錯誤，操作已取消。");
                    }
                },
                error: function () {
                    alert('密碼驗證失敗，請稍後再試。');
                }
            });
        });
    });
    </script>
</body>