@{
    var Capital_List = ViewBag.Capital_List as List<admin_web.Models.Mtapiuse.DisplayAccountCreate_Model.CapitalRecord>;
    // var NextLogin_List = ViewBag.NextLogin_List as List<admin_web.Models.Mtapiuse.DisplayAccountCreate_Model.NextLogin_Record>;
}

<h1>@ViewData["Title"]</h1>

<button type="button" id="DownloadHistoryLog" class="btn btn-outline-success" data-bs-toggle="tooltip" data-bs-placement="top" title="僅會記錄工具創建成功的帳號">下載歷史紀錄</button>

@*<button type="button" id="DownloadRule" class="btn btn-outline-success" data-bs-toggle="tooltip" data-bs-placement="top" title="若欲更新規範，更改完後，連同附件通知自動化團隊">下載規範</button>*@

<button type="button" id="#" class="btn btn-outline-primary" data-bs-toggle="offcanvas" data-bs-target="#offcanvasScrolling" aria-controls="offcanvasScrolling">查看資金池及當前帳號數</button>

@*<button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#ConfigModal">修改起始Login設置</button>*@

<a href="/Mtapi/CreateDisplayAccountTest" class="btn btn-primary">前往測試環境</a>

<hr />

<div class="form-check">
    <input class="form-check-input" type="radio" name="flexRadioDefault" id="ProxyRadioDefault" checked>
    <label class="form-check-label" for="ProxyRadioDefault">
        Proxy
    </label>
</div>
<div class="form-check">
    <input class="form-check-input" type="radio" name="flexRadioDefault" id="DCRadioDefault" disabled>
    <label class="form-check-label" for="DCRadioDefault">
        DC
    </label>
</div>

<div class="btn-toolbar" role="toolbar">
    <div class="input-group me-2" role="group">
        <input type="file" class="form-control" id="FileInput" name="uploadedFile" accept=".xlsx" required />
        <button type="submit" class="btn btn-outline-primary" id="executeButton">執行</button>
        <button type="submit" id="TemplateDownload" data-bs-toggle="tooltip" data-bs-placement="top" title="若欲更新規範，更改完後，連同附件通知自動化團隊" class="btn btn-outline-info">範本/規範</button>
    </div>
</div>

<div id="logView" style="display: none; padding-top: 50px;">
    <table id="logTable" class="table table-striped table-bordered nowrap">
        <thead id="logTableHeader"></thead>
        <tbody id="logTableBody"></tbody>
    </table>
</div>

<!-- Scrolling -->
<div class="offcanvas offcanvas-end" data-bs-scroll="true" data-bs-backdrop="false" tabindex="-1" id="offcanvasScrolling" aria-labelledby="offcanvasScrollingLabel" style="width:700px">
    <div class="offcanvas-header">
        <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        <div class="d-flex align-items-center">
            <h5 class="offcanvas-title me-3" id="offcanvasScrollingLabel">展示帳號當前資金池及帳號數量</h5>
            <button type="button" id="RefreshCapital" class="btn btn-outline-primary">刷新</button>
        </div>
    </div>
    <div class="offcanvas-body">
        <div class="table-container">
            <table id="capital_pool" class="table table-striped">
                <thead>
                    <tr>
                        <th>品牌</th>
                        <th>帳號數量</th>
                        <th>資金池</th>
                        <th>最後更新時間</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Capital_List)
                    {
                        <tr>
                            <td>@row.BRAND</td>
                            <td>@row.TESR_ACCOUNT</td>
                            <td>@row.TESR_BALANCE</td>
                            <td>@row.UPDATE_TIME</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Bootstrap 5 Bundle (includes Popper.js) -->
    <script src="https://cdn.datatables.net/1.13.3/js/jquery.dataTables.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/2.1.4/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/2.1.4/js/dataTables.bootstrap5.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/fixedcolumns/5.0.1/js/dataTables.fixedColumns.js"></script>
    <script src="https://cdn.datatables.net/fixedcolumns/5.0.1/js/fixedColumns.bootstrap5.js"></script>

    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.3/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/2.1.4/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.0/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/fixedcolumns/5.0.1/css/fixedColumns.bootstrap5.css">

    <script>
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
          return new bootstrap.Tooltip(tooltipTriggerEl)
        })

        $('#TemplateDownload').on('click', function () {
            var output_path = "DisplayAccountCreate\\Template";
            var fileName = "Template.xlsx";
            var downloadUrl = '@Url.Action("DownloadFile", "Universal")' +
                                '?output_path=' + encodeURIComponent(output_path) +
                                '&FileName=' + encodeURIComponent(fileName);
            window.location.href = downloadUrl;
        });

        $(document).on('click', '#executeButton', function (e) {
            e.preventDefault();

            $.ajax({
                url: '/Universal/Insert_Usage_Log',
                type: 'POST',
                data: {
                    Tool: '展示帳號創建工具',
                    Remark: '執行工具'
                },
                success: function () {
                    console.log("Log Insert Success.");
                },
                error: function (xhr, status, error) {
                    console.error("Error triggering log insertion:", error);
                }
            });

            var mode = $('#ProxyRadioDefault').is(':checked') ? 'proxy' : $('#DCRadioDefault').is(':checked') ? 'dc' : '';

            if (mode == '') {
                alert("設置Proxy/DC時發生錯誤");
                return;
            }

            $('#logView').hide();
            if ($.fn.DataTable.isDataTable('#logTable')) {
                $('#logTable').DataTable().clear().destroy();
            }

            $('#logTableHeader').empty();
            $('#logTableBody').empty();

            showLoading("Executing");

            var fileInput = $('#FileInput')[0];
            var file = fileInput.files[0];

            if (!file) {
                alert('請選擇文件');
                hideLoading();
                return;
            }

            var formData = new FormData();
            formData.append('mode', mode);
            formData.append('file', file);

            $.ajax({
                url: '/Mtapi/CreateDisplayAccount_Program',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (response) {
                    var logViewModel = response;

                    if (logViewModel) {
                        $('#logView').show();

                        var headerRow = '<tr>';
                        logViewModel.headers.forEach(function (header) {
                            headerRow += '<th>' + header + '</th>';
                        });
                        headerRow += '</tr>';
                        $('#logTableHeader').html(headerRow);

                        var tableBody = $('#logTableBody');
                        tableBody.empty();
                        logViewModel.records.forEach(function (record) {
                            var row = '<tr>';
                            Object.values(record).forEach(function (value) {
                                row += '<td>' + value + '</td>';
                            });
                            row += '</tr>';
                            tableBody.append(row);
                        });

                        $('#logTable').DataTable({
                            destroy: true,
                            paging: true,
                            searching: true,
                            ordering: true,
                            responsive: true,
                            lengthChange: true,
                            scrollY: 1000,
                            scrollCollapse: true,
                            fixedColumns: {
                                leftColumns: 4,
                            }
                        });
                        hideLoading();
                    } else {
                        alert("發生不可預期的錯誤");
                        hideLoading();
                    }
                },
                error: function (error) {
                    hideLoading();
                    alert(error.responseText);
                }
            });
        });

        $('#DownloadHistoryLog').on('click', function () {
            $.ajax({
                url: '/Universal/Insert_Usage_Log',
                type: 'POST',
                data: {
                    Tool: '展示帳號創建工具',
                    Remark: '下載歷史紀錄'
                },
                success: function () {
                    console.log("Log Insert Success.");
                },
                error: function (xhr, status, error) {
                    console.error("Error triggering log insertion:", error);
                }
            });
            var downloadUrl = '@Url.Action("CreateDisplayAccount_ExportHistoryLog","Mtapi")';
            window.location.href = downloadUrl;
        });

        $('#DownloadRule').on('click', function () {
            $.ajax({
                url: '/Universal/Insert_Usage_Log',
                type: 'POST',
                data: {
                    Tool: '展示帳號創建工具',
                    Remark: '下載品牌規範'
                },
                success: function () {
                    console.log("Log Insert Success.");
                },
                error: function (xhr, status, error) {
                    console.error("Error triggering log insertion:", error);
                }
            });

            var output_path = "DisplayAccountCreate\\Config";
            var FileName = "Brand_Rule.xlsx";
            var downloadUrl = '@Url.Action("DownloadFile", "Universal")' +
                                '?output_path=' + encodeURIComponent(output_path) +
                                '&FileName=' + encodeURIComponent(FileName);
            window.location.href = downloadUrl;
        });

        $('#RefreshCapital').click(function () {
            $.ajax({
                url: '/Universal/Insert_Usage_Log',
                type: 'POST',
                data: {
                    Tool: '展示帳號創建工具',
                    Remark: '刷新資料表'
                },
                success: function () {
                    console.log("Log Insert Success.");
                },
                error: function (xhr, status, error) {
                    console.error("Error triggering log insertion:", error);
                }
            });

            showLoading("刷新資料中");

            $.ajax({
                url: '/Mtapi/CreateDisplayAccount_RefreshCapital',
                method: 'GET',
                success: function (data) {
                    var $tbody = $('#capital_pool tbody');
                    $tbody.empty();

                    $.each(data, function (index, record) {
                        var $row = $('<tr></tr>');
                        $row.append('<td>' + record.brand + '</td>');
                        $row.append('<td>' + record.tesR_ACCOUNT + '</td>');
                        $row.append('<td>' + record.tesR_BALANCE + '</td>');
                        $row.append('<td>' + record.updatE_TIME + '</td>');
                        $tbody.append($row);
                    });
                },
                error: function (xhr, status, error) {
                    console.error('Error:', error);
                    alert('刷新失敗，請稍後再試');
                },
                complete: function () {
                    hideLoading();
                }
            });
        });
    </script>
}