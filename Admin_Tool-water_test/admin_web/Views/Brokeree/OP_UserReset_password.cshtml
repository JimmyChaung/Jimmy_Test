@model List<admin_web.Models.Brokeree.Op_userinfo>

@{
    ViewData["Title"] = "使用者密碼重置";
}

<!DOCTYPE html>
<html>
<head>
    <title>使用者密碼重置</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
</head>
<body>
    <div class="container">
        <h1 class="mt-3">使用者密碼重置</h1>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }

        @if (Model.Count > 0)
        {
            <form method="post" asp-action="UpdateUserPassword">
                <table id="userTable" class="table table-bordered border-dark">
                    <thead class="table-light">
                        <tr>
                            <th style="display:none">ID</th>
                            <th>使用者名稱</th>
                            <th>密碼</th>
                            <th>伺服器名稱</th>
                            <th>伺服器URL</th>
                            <th>config_set</th>
                            <th>操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            <tr>
                                <td style="display:none">
                                    <input type="hidden" name="users[@i].Id" value="@Model[i].Id" />
                                    @Model[i].Id
                                </td>
                                <td>
                                    <input type="text" name="users[@i].fa_user" value="@Model[i].fa_user" class="form-control" readonly />
                                </td>
                                <td>
                                    <div class="input-group">
                                        <input type="password" name="users[@i].fa_pass" id="password_@i" value="@Model[i].fa_pass" class="form-control" />
                                        <button type="button" class="btn btn-outline-secondary toggle-password" data-target="password_@i">
                                            <i class="bi bi-eye-slash-fill"></i>
                                        </button>
                                    </div>
                                </td>
                                <td>@Model[i].server_name</td>
                                <td>@Model[i].op_url</td>
                                <td>
                                    <input type="text" name="users[@i].config_set" value="@Model[i].config_set" />
                                </td>
                                <td>
                                    <button type="submit" class="btn btn-success btn-sm" name="updateUserId" value="@Model[i].Id">更新</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <button type="submit" class="btn btn-success">儲存所有修改</button>
            </form>
        }
        else
        {
            <p class="text-danger">未找到使用者資料。</p>
        }
    </div>

    @section Scripts {
        <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
        <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
        <script>
            $(document).ready(function () {
                // 啟用 DataTables
                $('#userTable').DataTable({
                    paging: true,
                    searching: true,
                    ordering: true,
                    info: true,
                    lengthMenu: [5, 10, 20, 50],
                    pageLength: 100,
                    language: {
                        lengthMenu: "顯示 _MENU_ 筆資料",
                        zeroRecords: "沒有符合的資料",
                        info: "第 _PAGE_ 頁，共 _PAGES_ 頁",
                        infoEmpty: "沒有可用的記錄",
                        infoFiltered: "(從 _MAX_ 筆記錄中篩選)",
                        search: "搜尋：",
                        paginate: {
                            first: "第一頁",
                            last: "最後一頁",
                            next: "下一頁",
                            previous: "上一頁"
                        }
                    }
                });

                // 密碼顯示切換
                $(".toggle-password").click(function () {
                    var inputId = $(this).data("target");
                    var inputField = $("#" + inputId);
                    var icon = $(this).find("i");

                    if (inputField.attr("type") === "password") {
                        inputField.attr("type", "text");
                        icon.removeClass("bi-eye-slash-fill").addClass("bi-eye-fill");
                    } else {
                        inputField.attr("type", "password");
                        icon.removeClass("bi-eye-fill").addClass("bi-eye-slash-fill");
                    }
                });
            });
        </script>
    }
</body>
</html>
