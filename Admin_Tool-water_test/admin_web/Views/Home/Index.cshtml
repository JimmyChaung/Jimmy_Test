@{
    var ToolMain = ViewBag.ToolMain as Tool_Info_Model.tool_info;
    ViewData["Title"] = ToolMain == null ? "Homepage" : ToolMain.Type == "Path" ? ToolMain.ToolName : "Homepage";
}
<html>
<head>
    <meta charset="utf-8" />
</head>
<body>
    <div class="container mt-4">
        <div class="row">
            @if (ToolMain == null)
            {
                @await Html.PartialAsync("_MainHomepage")
            }
            else
            {
                @await Html.PartialAsync("_SubHomepage")
            }
        </div>
    </div>
</body>
</html>

@section Scripts{
    <script>
        $(document).ready(function () {
            $('.custom-list-item').on('click', function (e) {
                e.preventDefault(); // 防止預設
                $('.custom-list-item').removeClass('active');
                $(this).addClass('active');
                var targetId = $(this).attr('href');
                $('.tab-pane').removeClass('show active');
                $(targetId).addClass('show active');
            });
        });
    </script>
}