@{
}

@{
    ViewData["Title"] = "Generate close_to_open.json & symbol_groups_config.json";
}

<h2>Generate close_to_open.json / symbol_groups_config.json</h2>

<form method="post" enctype="multipart/form-data" action="/CloseToOpen/Generate">
    <div>
        <label>MT4 Dynamic Leverage YAML</label>
        <input type="file" name="mt4" accept=".yaml,.yml" required />
    </div>

    <div>
        <label>MT5 Dynamic Leverage YAML</label>
        <input type="file" name="mt5" accept=".yaml,.yml" required />
    </div>

    <br />

    <button type="submit">產生 JSON</button>
</form>
