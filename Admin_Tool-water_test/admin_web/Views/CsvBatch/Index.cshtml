}
<h2>CSV 批量修改</h2>

<form method="post" enctype="multipart/form-data" action="/CsvBatch/Run">
    <div>
        <label>A.csv 規則檔</label>
        <input type="file" name="rules" accept=".csv" required />

        <div style="margin-top:5px;">
            <span>範例下載：</span>
            <a href="/sample/OZ.csv" target="_blank">OZ範例</a>
            |
            <a href="/sample/PE.csv" target="_blank">PE範例</a>
        </div>
    </div>

    <div>
        <label>B CSV 檔案，可多選(可用Ctrl+A全選)</label>
        <input type="file" name="csvFiles" accept=".csv" multiple required />
    </div>

    <br />
    <button type="submit">執行修改</button>
</form>
