<script>
    function loadPartial(name) {
        fetch(`/Querysql/${name}`)
            .then(res => res.text())
            .then(html => {
                document.getElementById("content-area").innerHTML = html;
                initSkillChoices(); // AJAX 載入後初始化 Choices
            });
    }

    // benson 初始化 Choices.js
    function initSkillChoices() {
        document.querySelectorAll('select.choices-select').forEach(function (el) {
            if (!el.dataset.choicesInit) {
                new Choices(el, {
                    removeItemButton: true,
                    searchEnabled: true
                });
                el.dataset.choicesInit = "true"; // 標記已初始化
            }
        });
    }

    // benson
    document.addEventListener('DOMContentLoaded', function () {
        // 初始化首頁已存在的 partial
        initSkillChoices();
        $(document).off('click', '#btn-server-mapping').on('click', '#btn-server-mapping', function () {
            console.log("按鈕被點擊");
            serverMapping();
            initSqlEditor();
        });
    });
    // DataLake 查詢 > benson
    $(document).on("change", ".dl-check", function () {
        let target = $(this).data("target");

        if ($(this).is(":checked")) {
            $(target).slideDown();
        } else {
            $(target).slideUp().find("input").val(""); // 清空
        }
    });

    // DataLake 查詢 > benson
    $(document).on("click", "#btnDL", function () {

        let selected = [];

        $(".dl-check:checked").each(function () {
            let key = $(this).data("key");
            let target = $(this).data("target");
            let inputVal = $(target).find("input").val() || "";

            let values = inputVal.split(",")
                .map(v => v.trim())
                .filter(v => v.length > 0);

            selected.push({ key: key, values: values });
        });

        if (selected.length === 0) {
            $("#dl_result").html("<span class='text-danger'>請至少勾選一個查詢項目！</span>");
            return;
        }

        // Server Select
        let servers = $("#serverSelect").val() || [];
        if (servers.length === 0) {
            $("#dl_result").html("<span class='text-danger'>請選擇 Server！</span>");
            return;
        }

        // Payload
        let payload = {
            servers: servers,
            items: selected
        };

        $.ajax({
            url: "/Querysql/RunDataLakeQuery",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(payload),
            success: function (result) {
                $("#dl_result").html(`<pre>${result}</pre>`);
            }
        });
    });

    // MySQL 查詢 > benson
    $(document).on("click", "#btnMy", function () {
        let isChecked = $("#my_ck").is(":checked");
        if (!isChecked) {
            $("#my_result").html("<span class='text-danger fw-bold'>請先勾選核取方框才能查詢！</span>");
            return;
        }
        $.ajax({
            url: "/Querysql/RunMysqlQuery",
            type: "POST",
            data: { enableFlag: isChecked },
            success: function (result) {
                $("#my_result").html(`<pre>${result}</pre>`);
            }
        });
    });

    // ========================================= Water =========================================
    // 清空編輯器 > water
    function clearEditor() {
        sqlEditor.setValue('');
        document.getElementById('modalResult').innerHTML = `
            <div class="text-center text-muted py-5">
                <i class="fas fa-search fa-3x mb-3 opacity-25"></i>
                <p>執行查詢後結果將顯示在這裡</p>
            </div>
        `;
    }

    // 載入範例 SQL > water
    function loadExample() {
        const exampleSQL = `SELECT *
        FROM asicdemoreport.mt4_config
        WHERE 1=1;`;

        sqlEditor.setValue(exampleSQL);
    }

    // 字元篩選
    function sanitizeSql(sql) {
        return sql.replace(/--.*$|;.*$/gm, '');
    }

    // 執行手動查詢 > water
    function executeManualQuery() {
        const sqlQuery = sqlEditor.getValue().trim();
        const limitQuery = "limit 100";
        const resultDiv = document.getElementById('modalResult');

        if (!sqlQuery) {
            resultDiv.innerHTML = `
                <div class="alert alert-warning alert-custom border-warning">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    請輸入 SQL 查詢語句
                </div>
            `;
            return;
        }

        // 顯示載入中
        resultDiv.innerHTML = `
                <div class="text-center py-5">
                    <div class="spinner-border text-success" role="status">
                        <span class="visually-hidden">執行中...</span>
                    </div>
                    <p class="mt-3 text-muted">正在執行查詢...</p>
                </div>
            `;

        if (!sqlQuery.trim().toLowerCase().startsWith("select")) {
            resultDiv.innerHTML = `
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    載入失敗：禁止 SELECT 以外的搜尋
                </div>
            `;
            return;
        }

        const sanitized_query = sanitizeSql(sqlQuery);

        const query = sanitized_query.concat(' ', limitQuery);

        // 模擬查詢執行
        setTimeout(() => {
            console.log(sqlQuery);

            console.log(query);
            $.ajax({
                url: "/Querysql/RunMysqlQueryByManual",
                type: "POST",
                contentType: "application/json",
                data: JSON.stringify({
                    SqlCode: query
                }),
                success: function (result) {
                    displayResults(result);
                },
                error: function (err) {
                    console.error(err);
                    resultDiv.innerHTML = `
                            <div class="alert alert-danger">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                載入失敗：${err.message}
                            </div>
                        `;
                }
            });
        }, 1000);
    }


    // 顯示查詢結果 > benson updata
    function displayResults(data) {
        const resultDiv = document.getElementById('modalResult');

        if (!data || data.length === 0) {
            resultDiv.innerHTML = `<div class="alert alert-info">查無資料</div>`;
            return;
        }

        // 1. 銷毀舊實體 (確保重新查詢時不會報錯)
        if ($.fn.DataTable.isDataTable('#reuslt_table')) {
            $('#reuslt_table').DataTable().destroy();
            resultDiv.innerHTML = "";
        }

        // 2. 自動取得欄位標題
        const columns = Object.keys(data[0]);
        const dtColumns = columns.map(col => ({
            data: col,
            title: col,
            defaultContent: ""
        }));

        // 3. 建立表格外殼 (只留 ID，內容由 DataTables 生成)
        resultDiv.innerHTML = `
        <div class="table-responsive">
            <table id="reuslt_table" class="table table-striped table-hover w-100">
            </table>
        </div>`;

        // 4. 初始化 DataTable
        myDataTable = $('#reuslt_table').DataTable({
            data: data,           // 這裡傳入完整的 10000 筆資料
            columns: dtColumns,
            scrollY: "300px",
            scrollX: true,
            page: false,
            // 2. 關閉底部的資訊顯示 (顯示第...筆)
            info: false,
            dom: 'lBrti',
            // --- 新增這個事件 ---
            drawCallback: function (settings) {
                // 取得總筆數 (或是過濾後的筆數)
                var api = this.api();
                var count = api.rows().count();

                // 將數字更新到你指定的 HTML 元素
                $('#record-count').text(count);
            },

            deferRender: true,    // 關鍵：只在畫面上渲染目前看得到的幾筆，效能極好
            pageLength: 10,       // 預設顯示 10 筆
            lengthMenu: [10, 50, 100], // 讓使用者切換顯示數量
            buttons: [
                {
                    extend: 'excel',
                    text: '隱藏的下載按鈕', // 這個文字不重要，因為你會隱藏它
                    className: 'buttons-excel d-none', // d-none 是 Bootstrap 的隱藏 class
                    exportOptions: {
                        modifier: {
                            page: 'all' // 確保下載全部資料
                        }
                    }
                }
            ],
            language: {
                url: "https://cdn.datatables.net/plug-ins/1.13.7/i18n/zh-HANT.json"
            }
        });

    }

    // 原本的執行查詢按鈕 > benson
    document.getElementById('btnMy').addEventListener('click', function () {
        const checkbox = document.getElementById('my_ck');
        const resultDiv = document.getElementById('my_result');

        if (!checkbox.checked) {
            resultDiv.innerHTML = `
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        請先勾選「同意執行查詢」
                    </div>
                `;
            return;
        }

        resultDiv.innerHTML = `
                <div class="alert alert-success">
                    <i class="fas fa-check-circle me-2"></i>
                    自動查詢執行成功！
                </div>
            `;
    });


    // server mapping
    function serverMapping() {
        //$("#mysql-table").innerHTML = `
        //    <div class="text-center py-5">
        //        <div class="spinner-border text-success"></div>
        //        <p class="mt-3 text-muted">正在重整查詢...</p>
        //    </div>
        //`;

        fetch('/Querysql/GetMysqlServerList')
            .then(res => res.json())
            .then(data => {
                if ($.fn.DataTable.isDataTable('#mysql-table')) {
                    console.log("destroy datatable");
                    $('#mysql-table').DataTable().destroy();
                }

                tt = data;
                let columns = [
                    { title: "Server Name", width: "60%" },
                    { title: "Sql Name", width: "40%" }
                ];

                let theadHtml = "<tr>";
                columns.forEach(col => {
                    theadHtml += `<th style="width:${col.width}">${col.title}</th>`;
                });
                theadHtml += "</tr>";
                $("#mysql-table thead").html(theadHtml);

                let tbodyHtml = "";
                data.forEach(s => {
                    tbodyHtml += `<tr>
                                <td>${s.serverInfo.serverName}</td>
                                <td>${s.serverInfo.sqlName}</td>
                              </tr>`;
                });
                $("#mysql-table tbody").html(tbodyHtml);

                serverTableMap = {};
                data.forEach(row => {
                    serverTableMap[row.serverInfo.sqlName] = row.tables ?? [];
                });

                initMySQLTable();
                console.log(serverTableMap);
            })
            .catch(console.error);
    }

    function initMySQLTable() {
        if ($.fn.DataTable.isDataTable('#mysql-table')) {
            $('#mysql-table').DataTable().destroy();
        }

        mysqlTable = $('#mysql-table').DataTable({
            scrollY: "400px",
            scrollX: true,
            scrollCollapse: true,
            paging: false,
            searching: true,
            ordering: true,
            info: false,
            dom: 'lrtip',
            autoWidth: false,
            language: {
                emptyTable: "暫無資料",
                zeroRecords: "找不到符合的資料"
            }
        });

        setTimeout(() => {
            mysqlTable.columns.adjust().draw();
        }, 300);

        $('#mysql-search').off('keyup').on('keyup', function () {
            mysqlTable.search(this.value).draw();
        });
    }

    // ========================================= CodeMirror =========================================
    function isIdentifierChar(ch) {
        return /[a-z0-9_.]/.test(ch)
    }

    function getReplaceRange(editor) {

        const cursor = editor.getCursor();
        const line = editor.getLine(cursor.line);

        let start = cursor.ch;

        while (start > 0 && isIdentifierChar(line[start - 1])) {
            start--;
        }

        return {
            from: CodeMirror.Pos(cursor.line, start),
            to: cursor
        };
    }

    function initSqlEditor() {
        const textarea = document.getElementById('sqlEditor');
        var oldEditor = textarea.querySelector('.CodeMirror');
        if (oldEditor) oldEditor.remove();
        if (!textarea) return;
        sqlEditor = CodeMirror.fromTextArea(textarea, {
            mode: "text/x-mysql",
            theme: "material",
            lineNumbers: true,
            autofocus: true,
            extraKeys: {
                "Tab": cm => {
                    if (cm.state.completionActive) {
                        cm.state.completionActive.widget.pick();
                    } else {
                        cm.showHint({ completeSingle: false });
                    }
                },
                "Ctrl-Space": "autocomplete"
            }
        });

        sqlEditor.setSize("100%", "450px");

        sqlEditor.on("inputRead", (cm, change) => {
            if (change.origin === "+input" && /[a-zA-Z_.]/.test(change.text[0])) {
                cm.showHint({ completeSingle: false });
            }
        });

        registerSqlHint();
    }

    function registerSqlHint() {
        CodeMirror.registerHelper("hint", "sql", function (editor) {
            const range = getReplaceRange(editor);
            const currentText = editor.getRange(range.from, range.to);
            const lowerText = currentText.toLowerCase();

            let list = [];
            const keywords = ["SELECT", "FROM", "WHERE", "JOIN", "LEFT JOIN", "GROUP BY", "ORDER BY", "LIMIT"];

            if (currentText.includes(".")) {
                const parts = currentText.split(".");
                const dbName = parts[0];
                const tableQuery = parts[1].toLowerCase();

                const tables = serverTableMap[dbName] || [];

                const filteredTables = tables.filter(t => t.toLowerCase().includes(tableQuery));

                return {
                    list: filteredTables,
                    from: CodeMirror.Pos(range.from.line, range.from.ch + dbName.length + 1),
                    to: range.to
                };
            }

            const dbNames = Object.keys(serverTableMap);
            const allFirstLevel = [...keywords, ...dbNames];

            list = allFirstLevel.filter(item =>
                item.toLowerCase().includes(lowerText)
            );

            return {
                list: list,
                from: range.from,
                to: range.to
            };
        });
    }

    // ========================================= Modal =========================================
    function showTablesModal(serverName, tables) {

        const list = tables.split(',');

        document.getElementById("tablesContent").innerHTML = `
            <ul class="list-group">
                ${list.map(t => `
                    <li class="list-group-item list-group-item-action"
                        style="cursor:pointer"
                        onclick="insertTable('${serverName}','${t}')">
                        ${t}
                    </li>
                `).join('')}
            </ul>
        `;

        $('#tablesModal').modal('show');
    }

    function insertTable(serverName, table) {

        closeModal();

        editor.setValue(`${serverName}.${table}`);
    }

    function closeModal() {
        $('#tablesModal').modal('hide');
    }
</script>



