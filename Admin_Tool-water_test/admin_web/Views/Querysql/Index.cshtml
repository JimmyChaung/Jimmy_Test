<!-- jQuery & DataTables JS -->


<script>

   //取的server list
$(function() {
    let retryCount = 0; // 記錄重試次數
    const maxRetries = 2; // 最多重試幾次

    async function loadDataLake() {
        try {// 1️⃣ 載入 PartialView
            await fetch("@Url.Action("DataLakePartial","Querysql")")
                .then(response => {
                    if (!response.ok) {
                        throw new Error("PartialView 載入失敗");
                    }
                    return response.text();
                })
                .then(html => {
                    document.getElementById("content-area").innerHTML = html;
                    console.log("PartialView 載入完成");
                });



            // 2️⃣ 使用 fetch 取得 JSON 資料
            const response = await fetch("@Url.Action("GetMtServers","Querysql")", {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json'
                }
            });

            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }

            const data = await response.json();
            console.log("收到 JSON:", data);

            // ⭐ 判斷沒資料時自動重載
            if ((!data || data.length === 0) && retryCount < maxRetries) {
                retryCount++;
                console.warn(`無資料，正在進行第 ${retryCount} 次重試...`);
                setTimeout(loadDataLake, 1500);
                return;
            }

            // ✅ 資料載入完成，延遲後一次性渲染
            setTimeout(function() {
                renderTable(data);
            }, 100);

        } catch (error) {
            console.error("發生錯誤:", error);

            if (retryCount < maxRetries) {
                retryCount++;
                console.warn(`錯誤重試 ${retryCount}/${maxRetries}`);
                setTimeout(loadDataLake, 1000);
            } else {
                console.error("達到最大重試次數");
                $("#datalake-table tbody").html("<tr><td colspan='2'>資料載入失敗</td></tr>");
            }
        }
    }

    // ⭐ 獨立的渲染函數
    function renderTable(data) {
        console.log("開始渲染表格，資料筆數:", data.length);

        // --- 渲染 thead ---
        let columns = [
            { title: "Server Name", width: "50%" },
            { title: "DL_SOURCE_SERVER", width: "50%" }
        ];

        let theadHtml = "<tr>";
        columns.forEach(col => {
            theadHtml += `<th style="width:${col.width}">${col.title}</th>`;
        });
        theadHtml += "</tr>";
        $("#datalake-table thead").html(theadHtml);

        // --- 渲染 tbody ---
        let tbodyHtml = "";
        if (data.length > 0) {
            data.forEach(s => {
                tbodyHtml += `<tr>
                                <td>${s.serverName}</td>
                                <td>${s.dlSourceServer}</td>
                              </tr>`;
            });
        } else {
            tbodyHtml = "<tr><td colspan='2' class='text-center'>查無資料</td></tr>";
        }
        $("#datalake-table tbody").html(tbodyHtml);

        // ✅ DOM 渲染完成後，再初始化 DataTable
        setTimeout(function() {
            initDataLakeTable();
            console.log("表格渲染完成");
        }, 150);
    }

    // 初始化 DataTable
    function initDataLakeTable() {
        // 銷毀舊的 DataTable 實例
        if ($.fn.DataTable.isDataTable('#datalake-table')) {
            $('#datalake-table').DataTable().destroy();
        }

        const table = $('#datalake-table').DataTable({
            scrollY: "500px",
            scrollX: true,
            scrollCollapse: true,
            paging: false,
            searching: true,
            ordering: true,
            info: false,
            dom: 'lrtip',
            autoWidth: false,
            // ⭐ 明確指定欄位寬度
            columnDefs: [
                { width: "50%", targets: 0 },
                { width: "50%", targets: 1 }
            ],
            // ⭐ 初始化完成後調整欄位
            initComplete: function() {
                console.log("DataTable 初始化完成");
                var api = this.api();

                // 強制調整欄位寬度
                setTimeout(function() {
                    api.columns.adjust().draw(false);
                    console.log("欄位寬度調整完成");
                }, 50);
            }
        });

        // 綁定搜尋功能
        $('#datalake-search').off('keyup').on('keyup', function() {
            table.search(this.value).draw();
        });
    }

    // 初始呼叫
    loadDataLake();
});


