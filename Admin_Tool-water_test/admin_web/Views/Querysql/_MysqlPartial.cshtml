<div>
    <h4 class="mb-3 text-success">MySQL 查詢</h4>

    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" id="my_ck" />
        <label class="form-check-label" for="my_ck">同意執行查詢</label>
    </div>
     
    <button id="btnMy" class="btn btn-success">執行查詢</button>
    <button class="btn btn-primary" id="btn-server-mapping" type="button" data-bs-toggle="collapse" data-bs-target="#manualQueryCollapse" aria-expanded="false" aria-controls="manualQueryCollapse">
        <i class="fas fa-code me-2"></i>手動查詢
    </button>

    <!-- 手動查詢 -->
    <div class="collapse" id="manualQueryCollapse">
        <div class="manual-query-section">
            <div class="section-header d-flex justify-content-between align-items-center">
                <h5 class="my-2">
                    <i class="fa fa-terminal mr-2" aria-hidden="true"></i>SQL 手動查詢編輯器
                </h5>
            </div>

            <div class="row g-3">
                <!-- 左側：SQL 編輯器 -->
                <div class="col-md-6">
                    <div class="editor-card">
                        <div class="card-header editor-header d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-file-code me-2"></i>SQL 編輯器 </span>
                            <div class="btn-group btn-group">
                                <button class="btn btn-outline-light rounded-start-1" onclick="clearEditor()" title="清空">
                                    <i class="fas fa-trash"></i>
                                </button>
                                <button class="btn btn-outline-light rounded-end-1" onclick="loadExample()" title="範例">
                                    <i class="fas fa-lightbulb"></i>
                                </button>
                                <div class="ml-2 d-flex gap-2">
                                    <button type="button" class="btn btn-secondary" data-bs-toggle="collapse" data-bs-target="#manualQueryCollapse">
                                        收合
                                    </button>
                                    <button type="button" class="btn btn-execute-collapse" onclick="executeManualQuery()">
                                        <i class="fas fa-play me-2"></i>執行查詢
                                    </button>
                                </div>
                            </div>
                        </div>
                        <textarea id="sqlEditor" class="form-control"></textarea>
                    </div>
                </div>

                <!-- 右側：ServerList 顯示 -->
                <div class="col-md-6">

                    <input type="text"
                           id="mysql-search"
                           class="form-control mb-2"
                           placeholder="搜尋 Server（例如 AU）">
                    @*<div class="server-card card">
                        <div class="card-header result-header d-flex justify-content-between">
                            <span><i class="fas fa-table me-2"></i>Server List</span>
                            <div class="btn-group btn-group-sm">
                                <button class="btn btn-outline-dark btn-sm" onclick="serverMapping()" title="Reload Server">
                                    <i class="fas fa-refresh"></i>
                                </button>
                            </div>
                        </div>
                        <div class="result-area" id="serverModalResult">
                        </div>
                    </div>*@
                    <div class="table-responsive w-100">
                        <table id="mysql-table"
                               class="table table-striped table-bordered table-hover table-sm"
                               style="width:100%">
                            <thead class="table-dark sticky-top">
                            </thead>
                            <tbody>
                                <!-- JS 填資料 -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- 結果顯示 -->
                <div class="row-md-6">
                    <div class="result-card card">
                        <div class="card-header result-header d-flex justify-content-between">
                            <span><i class="fas fa-table me-2"></i>查詢結果</span>
                            <div class="btn-group btn-group-sm gap-2">
                                <select class="form-select" id="limitSearch">
                                    <option value="LIMIT 50" selected>limit to 50 rows</option>
                                    <option value="LIMIT 100">limit to 100 rows</option>
                                    <option value="LIMIT 500">limit to 500 rows</option>
                                    <option value="LIMIT 1000">limit to 1000 rows</option>
                                </select>
                                <button class="btn btn-outline-dark btn-sm" onclick="executeManualQuery()" title="Reload Search">
                                    <i class="fas fa-refresh"></i>
                                </button>
                            </div>
                        </div>
                        <div class="result-area" id="modalResult">
                            <div class="text-center text-muted py-5">
                                <i class="fas fa-search fa-3x mb-3 opacity-25"></i>
                                <p>執行查詢後結果將顯示在這裡</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="my_result" class="mt-3"></div>

    <div class="modal fade" id="tablesModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Server Tables</h5>
                    <button class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body" id="tablesContent">
                </div>

            </div>
        </div>
    </div>
</div>
