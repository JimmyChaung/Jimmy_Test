<div id="datalake-container">
    <h4 class="mb-3 text-success">DATALAKE 查詢</h4>

    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" id="my_ck" />
        <label class="form-check-label" for="my_ck">同意執行查詢</label>
    </div>

    <button id="btnMy" class="btn btn-success">執行查詢</button>
    <button class="btn btn-primary" type="button" data-bs-toggle="collapse" data-bs-target="#manualQueryCollapse" aria-expanded="false" aria-controls="manualQueryCollapse">
        <i class="fas fa-code me-2"></i>手動查詢
    </button>

    <!-- 手動查詢 -->
    <div class="collapse" id="manualQueryCollapse">
        <div class="manual-query-section">
            <div class="section-header d-flex justify-content-between align-items-center">
                <h5 class="my-2">
                    <i class="fa fa-terminal mr-2" aria-hidden="true"></i>DATALAKE 手動查詢編輯器
                </h5>
            </div>

            <div class="row g-3">
                <div class="col-md-6 d-flex flex-column" style="min-height: 600px;">

                    <div class="editor-card d-flex flex-column flex-grow-1">

                        <div class="card-header editor-header d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-file-code me-2"></i>DATALAKE 編輯器 </span>
                            <div class="btn-group btn-group">
                                <button class="btn btn-outline-light rounded-start-1" onclick="clearEditor()" title="清空">
                                    <i class="fas fa-trash"></i>
                                </button>
                                <button class="btn btn-outline-light rounded-end-1" onclick="loadExample()" title="範例">
                                    <i class="fas fa-lightbulb"></i>
                                </button>
                                <div class="ml-2 d-flex gap-2">
                                    <button type="button" class="btn btn-secondary" data-bs-toggle="collapse" data-bs-target="#manualQueryCollapse">
                                        收合
                                    </button>
                                    <button type="button" class="btn btn-execute-collapse" onclick="executedatalakeQuery()">
                                        <i class="fas fa-play me-2"></i>執行查詢
                                    </button>
                                </div>
                            </div>
                        </div>

                        <textarea id="datalakeEditor"
                                  class="form-control flex-grow-1"
                                  style="border-radius: 0; resize: none;"
                                  placeholder="-- 請輸入 SQL 查詢語句&#10;-- 例如: SELECT * FROM users WHERE id = 1;"></textarea>

                    </div>
                </div>

                <!-- 左側其他內容 -->
                <div class="col-md-6">
                    <input type="text"
                           id="datalake-search"
                           class="form-control mb-2"
                           placeholder="搜尋 Server（例如 AU）">

                    <!-- ⭐ 一定要包這層 -->
                    <div class="table-responsive w-100">
                        <table id="datalake-table"
                               class="table table-striped table-bordered table-hover table-sm"
                               style="width:100%">
                            <thead class="table-dark sticky-top">

                            </thead>
                            <tbody>
                                <!-- JS 填資料 -->
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- 結果顯示 -->
                <div class="row-md-6">
                    <div class="result-card card">
                        <div class="card-header result-header d-flex justify-content-between">
                            <span><i class="fas fa-table me-2"></i>查詢結果</span>

                            <div class="ms-auto">
                                @*<button class="btn btn-outline-dark btn-sm me-1" onclick="executeManualQuery()" title="Reload Search">
            <i class="fas fa-refresh"></i>
        </button>*@
                                <div class="custom-info">
                                    目前資料總計：<span id="record-count">0</span> 筆
                                </div>
                                <button type="button" class="btn btn-success btn-sm" onclick="downloadExcel()">
                                    <i class="fas fa-file-excel me-2"></i>下載 XLSX
                                </button>
                                <button type="button" class="btn btn-success btn-sm" onclick="downloadCsv()">
                                    <i class="fas fa-file-excel me-2"></i>下載所有資料(.csv)
                                </button>
                            </div>
                        </div>
                        <div id="modalResult">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="my_result" class="mt-3"></div>

</div>


