@model ExcelViewModel
@{
    List<string> FileNameList = ViewBag.FileNameList as List<string>;
    string FileName = ViewBag.FileName as string;
    int index = 1;
}
<head>
    <meta charset="utf-8" />
    <style type="text/css">
        .tg {
            border-collapse: collapse;
            border-spacing: 0;
        }

            .tg td {
                border-color: black;
                border-style: solid;
                border-width: 1px;
                font-family: Arial, sans-serif;
                font-size: 14px;
                overflow: hidden;
                padding: 10px 5px;
                word-break: normal;
            }

            .tg th {
                border-color: black;
                border-style: solid;
                border-width: 1px;
                font-family: Arial, sans-serif;
                font-size: 14px;
                font-weight: normal;
                overflow: hidden;
                padding: 10px 5px;
                word-break: normal;
            }

            .tg .tg-0lax {
                text-align: left;
                vertical-align: top
            }
    </style>
</head>

<body>
    <h1>@ViewData["Title"]</h1>
    <div class="btn-group" role="group" aria-label="Basic example">
        <button type="submit" id="RunButton" class="btn btn-success">Run</button>
        <button type="submit" id="Download" class="btn btn-primary" @(FileNameList != null ? "enabled" : "disabled")>Download File</button>
    </div>
    <h2 id="RunResult"></h2>

    <!-- 主畫面表格 -->
    <div style="margin-bottom:50px">
        @if (FileNameList != null)
        {
            <div class="d-flex align-items-center">
                <h5>資料日期：@FileNameList.Last()</h5>
            </div>
            <ul class="nav nav-tabs" id="myTab" role="tablist">
                @foreach (var item in Model.Tabs)
                {
                    string classSet = index == 1 ? "nav-link active" : "nav-link";
                    string ariaControl = index == 1 ? "home" : "contact";
                    string ariaSelected = index == 1 ? "true" : "false";
                    <li class="nav-item" role="presentation">
                        <button class="@classSet" id="@($"id{index}")" data-bs-toggle="tab" data-bs-target="@($"#section{index}")" type="button" role="tab" aria-controls="@ariaControl" aria-selected="@ariaSelected">@item.Name.ToString()</button>
                    </li>
                    index++;
                }
            </ul>
            <div class="tab-content" id="myTabContent">
                @{ index = 1; }
                @foreach (var item in Model.Tabs)
                {
                    <div class="tab-pane fade" id="@($"section{index}")" role="tabpanel" aria-labelledby="@($"id{index}")">
                        <table id="@(item.DataList.Any() ? "example" : "example1")" class="table table-striped table-bordered nowrap" style="width:100%">
                            <thead>
                                <tr>
                                    @foreach (string Header in item.HeaderList)
                                    {
                                        <th>@Header</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @if (item.Check)
                                {
                                    @foreach (var Data in item.DataList)
                                    {
                                        <tr>
                                            @foreach (var item2 in Data)
                                            {
                                                <td>@item2</td>
                                            }
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="8">「@item.Name」資料無生成</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    index++;
                }
            </div>
        }
        else
        {
            <div class="d-flex align-items-center">
                <h5>無任何資料，請執行工具以產生新資料</h5>
            </div>
        }
    </div>

    <!-- Bootstrap JS and dependencies -->
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>

@section Scripts {
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.js"></script>

    <!-- Bootstrap 5 Bundle (includes Popper.js) -->
    <script src="https://cdn.datatables.net/1.13.3/js/jquery.dataTables.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.0/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/2.1.4/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/2.1.4/js/dataTables.bootstrap5.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.1/dist/js/bootstrap.bundle.min.js"></script>

    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.3/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/2.1.4/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.1/dist/css/bootstrap.min.css">

    <script>
        $(document).ready(function () {
            $('.tab-pane').addClass('show active');
            $('#myTabContent [id^="section"] #example').DataTable({
                responsive: true,
                scrollX: true
            });
            $('.tab-pane').removeClass('show active');
            $('#myTabContent .tab-pane:first').addClass('show active');
        });

        // exe
        $(document).ready(function () {
            $('#RunButton').on('click', function () {
                $.ajax({
                    url: '/Universal/Insert_Usage_Log',
                    type: 'POST',
                    data: {
                        Tool: '剩餘組別排查MT4',
                        Remark: '執行工具'
                    },
                    success: function () {
                        console.log("Log Insert Success.");
                    },
                    error: function (xhr, status, error) {
                        console.error("Error triggering log insertion:", error);
                    }
                });

                showLoading("正在執行 剩餘組別排查工具MT4");

                var formData = new FormData();
                formData.append('tool_path', 'Check Remain Group Tool');
                formData.append('output_path', 'CheckList');
                formData.append('exe_name', "main.exe");
                formData.append('DeleteAllFile', true);

                $('#RunButton').prop('disabled', true);
                $('#Download').prop('disabled', true);
                $('#Setting').prop('disabled', true);

                $.ajax({
                    url: '@Url.Action("RunExe", "Universal")',
                    type: 'POST',
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (response) {
                        window.location.href = `RemainGroup`
                    },
                    error: function (error) {
                        hideLoading();
                        $('#RunButton').prop('disabled', false);
                        $('#Download').prop('disabled', @Html.Raw(Json.Serialize(FileNameList)) == null ? true : false);
                        $('#Setting').prop('disabled', false);
                        $('#RunResult').html(`<p class="text-danger">${error.responseText}</p>`);
                    }
                });
            });
        });

        // download
        $(document).ready(function () {
            var output_path = "Check Remain Group Tool\\CheckList";
            var fileName = @Html.Raw(Json.Serialize(FileName));
            $('#Download').on('click', function () {
                $.ajax({
                    url: '/Universal/Insert_Usage_Log',
                    type: 'POST',
                    data: {
                        Tool: '剩餘組別排查MT4',
                        Remark: '下載檔案'
                    },
                    success: function () {
                        console.log("Log Insert Success.");
                    },
                    error: function (xhr, status, error) {
                        console.error("Error triggering log insertion:", error);
                    }
                });
                var downloadUrl = '@Url.Action("DownloadFile", "Universal")' +
                                    '?output_path=' + encodeURIComponent(output_path) +
                                    '&FileName=' + encodeURIComponent(fileName);
                window.location.href = downloadUrl;
            });
        });
    </script>

    @* Bootstrap 5 *@
    <!-- CSS only -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-F3w7mX95PdgyTmZZMECAngseQB83DfGTowi0iMjiWaeVhAn4FJkqJByhZMI3AhiU" crossorigin="anonymous">

    <!-- JavaScript Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.1/dist/js/bootstrap.bundle.min.js" integrity="sha384-/bQdsTh/da6pkI1MST/rWKFNjaCP5gBSY4sEBT38Q/9RBh9AH40zEOg7Hlq2THRZ" crossorigin="anonymous"></script>
}
